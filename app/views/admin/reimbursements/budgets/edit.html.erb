<p class="mb-3">
  <%= link_to "← All budgets", admin_reimbursements_budgets_path, class: "text-sm text-blue-700 hover:underline" %>
</p>

<%= render CardComponent.new(title: "Edit #{@budget.name.presence || 'budget'}") do %>
  <%= form_with url: admin_reimbursements_budget_path(@budget.record_id), method: :patch,
                class: "flex flex-col gap-4" do %>
    <div class="flex flex-wrap gap-4">
      <div>
        <%= label_tag :name, "Name", class: "block text-sm font-medium" %>
        <%= text_field_tag :name, @budget.name,
                           class: "border border-gray-300 rounded px-2 py-1 text-sm w-72" %>
      </div>
      <div>
        <%= label_tag :nominal_code, "Nominal code", class: "block text-sm font-medium" %>
        <%= text_field_tag :nominal_code, @budget.nominal_code,
                           class: "border border-gray-300 rounded px-2 py-1 text-sm w-40" %>
      </div>
      <div>
        <%= label_tag :budget_type, "Type", class: "block text-sm font-medium" %>
        <%= select_tag :budget_type,
                       options_for_select(%w[Expense Income], @budget.budget_type),
                       class: "border border-gray-300 rounded px-2 py-1 text-sm" %>
      </div>
      <div>
        <%= label_tag :initial_budget, "Initial budget (£)", class: "block text-sm font-medium" %>
        <%= number_field_tag :initial_budget, @budget.initial_budget, step: "0.01",
                             class: "border border-gray-300 rounded px-2 py-1 text-sm w-40" %>
      </div>
    </div>

    <label class="inline-flex items-center gap-2 text-sm">
      <%= check_box_tag :active, "1", @budget.active %>
      Visible to submitters
    </label>

    <div>
      <%= label_tag :owner_ids, "Owners", class: "block text-sm font-medium" %>
      <%= select_tag "owner_ids[]",
                     options_for_select(@people.map { |p| [ p.name.presence || p.email, p.record_id ] },
                                        @budget.owner_ids),
                     multiple: true, size: [ @people.size, 6 ].min.clamp(3, 6),
                     class: "border border-gray-300 rounded px-2 py-1 text-sm w-72" %>
      <p class="text-xs text-gray-500 mt-1">Ctrl/Cmd-click to select more than one.</p>
    </div>

    <div>
      <%= label_tag :notes, "Notes", class: "block text-sm font-medium" %>
      <%= text_area_tag :notes, @budget.notes, rows: 3,
                        class: "border border-gray-300 rounded px-2 py-1 text-sm w-full max-w-xl" %>
    </div>

    <div>
      <%= submit_tag "Save budget", class: btn_classes(:primary) %>
    </div>
  <% end %>
<% end %>

<%= render CardComponent.new(title: "Financials (read-only)", html_class: "mt-4") do %>
  <p class="text-sm text-gray-600 mb-3">
    Airtable computes these from the expenses and forecasts linked to this budget.
  </p>
  <dl class="grid grid-cols-2 sm:grid-cols-3 gap-x-6 gap-y-2 text-sm">
    <div><dt class="text-gray-500">Current forecast</dt><dd class="font-medium"><%= budget_money(@budget.current_forecast) %></dd></div>
    <div><dt class="text-gray-500">Committed</dt><dd class="font-medium"><%= budget_money(@budget.committed_amount) %></dd></div>
    <div><dt class="text-gray-500">Total paid</dt><dd class="font-medium"><%= budget_money(@budget.total_paid) %></dd></div>
    <div><dt class="text-gray-500">Remaining</dt><dd class="font-medium"><%= budget_money(@budget.remaining) %></dd></div>
    <div>
      <dt class="text-gray-500">Variance</dt>
      <dd class="font-medium <%= @budget.variance && @budget.variance.negative? ? 'text-red-600' : '' %>">
        <%= budget_money(@budget.variance) %>
      </dd>
    </div>
  </dl>
<% end %>

<%= render CardComponent.new(title: "Budget forecasts", html_class: "mt-4") do %>
  <p class="text-sm text-gray-600 mb-3">
    A versioned log of projected-spend updates for this budget. The latest feeds the
    current forecast above. Add a new one whenever the projection changes.
  </p>

  <%= form_with url: forecast_admin_reimbursements_budget_path(@budget.record_id), method: :post,
                class: "flex flex-wrap items-end gap-3 mb-4" do %>
    <div>
      <%= label_tag :amount, "Amount (£, excl. VAT)", class: "block text-sm font-medium" %>
      <%= number_field_tag :amount, nil, step: "0.01",
                           class: "border border-gray-300 rounded px-2 py-1 text-sm w-40" %>
    </div>
    <div>
      <%= label_tag :date, "Date", class: "block text-sm font-medium" %>
      <%= date_field_tag :date, Date.current,
                         class: "border border-gray-300 rounded px-2 py-1 text-sm" %>
    </div>
    <div class="grow">
      <%= label_tag :reason, "Reason / notes", class: "block text-sm font-medium" %>
      <%= text_field_tag :reason, nil,
                         class: "border border-gray-300 rounded px-2 py-1 text-sm w-full" %>
    </div>
    <%= submit_tag "Add forecast", class: btn_classes(:primary, :sm) %>
  <% end %>

  <% if @forecasts.empty? %>
    <p class="py-2 text-center text-gray-600">No forecasts logged yet.</p>
  <% else %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-left text-gray-500 border-b border-gray-200">
            <th class="py-2 pr-3">Date</th>
            <th class="py-2 pr-3 text-right">Amount</th>
            <th class="py-2">Reason / notes</th>
          </tr>
        </thead>
        <tbody>
          <% @forecasts.each do |forecast| %>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-3 whitespace-nowrap"><%= forecast.date&.strftime("%d %b %Y") || "—" %></td>
              <td class="py-2 pr-3 text-right"><%= budget_money(forecast.amount) %></td>
              <td class="py-2"><%= forecast.reason.presence || "—" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
<% end %>
