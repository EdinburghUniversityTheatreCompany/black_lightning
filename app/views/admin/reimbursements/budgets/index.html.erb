<p class="mb-3 text-gray-600">
  Every budget category from Airtable with its live financials. Initial, current forecast,
  committed and total paid feed remaining and variance — those five are Airtable rollups
  shown read-only here. Edit a budget to change its name, nominal code, owners, notes,
  initial figure and whether submitters can see it, or to log a projected-spend update.
</p>

<%= render CardComponent.new(title: "#{@budgets.size} #{'budget'.pluralize(@budgets.size)}") do %>
  <% if @budgets.empty? %>
    <p class="py-4 text-center text-gray-600">No budgets found.</p>
  <% else %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-left text-gray-500 border-b border-gray-200">
            <th class="py-2 pr-3">Budget</th>
            <th class="py-2 pr-3">Type</th>
            <th class="py-2 pr-3">Visible</th>
            <th class="py-2 pr-3 text-right">Initial</th>
            <th class="py-2 pr-3 text-right">Current forecast</th>
            <th class="py-2 pr-3 text-right">Committed</th>
            <th class="py-2 pr-3 text-right">Total paid</th>
            <th class="py-2 pr-3 text-right">Remaining</th>
            <th class="py-2 pr-3 text-right">Variance</th>
            <th class="py-2 pr-3">Owners</th>
            <th class="py-2"></th>
          </tr>
        </thead>
        <tbody>
          <% @budgets.each do |budget| %>
            <tr class="border-b border-gray-100 align-top">
              <td class="py-2 pr-3">
                <span class="font-medium"><%= budget.name.presence || "—" %></span>
                <% if budget.nominal_code.present? %>
                  <span class="text-gray-500">· <%= budget.nominal_code %></span>
                <% end %>
              </td>
              <td class="py-2 pr-3"><%= budget.budget_type %></td>
              <td class="py-2 pr-3">
                <% if budget.active %>
                  <%= render BadgeComponent.new(type: :success, pill: true).with_content("Visible") %>
                <% else %>
                  <%= render BadgeComponent.new(type: :secondary, pill: true).with_content("Hidden") %>
                <% end %>
              </td>
              <td class="py-2 pr-3 text-right"><%= budget_money(budget.initial_budget) %></td>
              <td class="py-2 pr-3 text-right"><%= budget_money(budget.current_forecast) %></td>
              <td class="py-2 pr-3 text-right"><%= budget_money(budget.committed_amount) %></td>
              <td class="py-2 pr-3 text-right"><%= budget_money(budget.total_paid) %></td>
              <td class="py-2 pr-3 text-right"><%= budget_money(budget.remaining) %></td>
              <td class="py-2 pr-3 text-right <%= budget.variance && budget.variance.negative? ? 'text-red-600' : '' %>">
                <%= budget_money(budget.variance) %>
              </td>
              <td class="py-2 pr-3">
                <%= budget_owner_names(budget, @people_by_id).presence || "—" %>
              </td>
              <td class="py-2 text-right whitespace-nowrap">
                <%= link_to "Edit", edit_admin_reimbursements_budget_path(budget.record_id),
                            class: btn_classes(:secondary, :sm) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
<% end %>
