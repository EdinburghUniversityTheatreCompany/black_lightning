<%# locals: (home_opportunities:) %>
<% cache home_opportunities do %>
<div class="card mt-3 mt-md-0">
  <div class="card-header">
    <h4 class="mb-0">Opportunities</h4>
  </div>

  <% if home_opportunities.empty? %>
    <div class="card-body">
      <%= display_block("No Opportunities", false) %>
    </div>
  <% else %>
    <ul class="list-group list-group-flush">
      <% home_opportunities.each do |opportunity| %>
        <li class="list-group-item">
          <h5 class="card-title mb-1">
            <%= link_to opportunity.title, get_involved_opportunities_path %>
          </h5>
          <p class="card-text mb-1">
            <small class="text-muted">Expires <%= opportunity.expiry_date.strftime("%-d %B %Y") %></small>
          </p>
          <p class="card-text">
            <%= truncate_markdown(opportunity.description, 100) %>
          </p>
        </li>
      <% end %>
    </ul>
  <% end %>

  <div class="card-footer d-flex justify-content-between align-items-center">
    <%= link_to "View all opportunities →", get_involved_opportunities_path %>
    <% if can?(:create, Opportunity) %>
      <%= link_to "Submit an Opportunity", new_get_involved_opportunity_path, class: "btn btn-primary btn-sm" %>
    <% end %>
  </div>
</div>
<% end %>
