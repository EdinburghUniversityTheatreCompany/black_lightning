<% can_act = can?(:approve, Admin::Proposals::Proposal) %>
<% redirect_param = { redirect_to: admin_proposals_calls_path } %>

<%= render CardComponent.new do %>
  <div class="callout callout-info mb-0">
    <p>
      Active proposals across every call. Awaiting Approval decisions happen before the General Meeting;
      Approved proposals are set to successful or unsuccessful after the General Meeting.
    </p>
    <% unless can_act %>
      <p class="mb-0"><em>You have view-only access. Contact an approver to make changes.</em></p>
    <% end %>
  </div>
<% end %>

<%= render CardComponent.new(title: "Open Calls") do %>
  <% if @open_calls.any? %>
    <% @open_calls.each do |call| %>
      <div class="flex flex-wrap gap-2 justify-between items-center <%= 'mt-3' unless call == @open_calls.first %>">
        <div>
          <h6 class="mb-0"><%= link_to call.name, admin_proposals_call_proposals_path(call) %></h6>
          <small class="text-gray-500">
            Submission deadline: <%= l(call.submission_deadline, format: :longy) %>
            &middot;
            Editing deadline: <%= l(call.editing_deadline, format: :longy) %>
          </small>
        </div>
        <%= get_link(Admin::Proposals::Proposal, :new, link_target: new_admin_proposals_proposal_path(call_id: call.id), link_text: "New Proposal") %>
      </div>
    <% end %>
  <% else %>
    <p class="mb-0"><em>There are no open calls.</em></p>
  <% end %>
<% end %>

<%= render CardComponent.new(flush: true) do |c| %>
  <% c.with_tools do %>
    <span class="text-base font-semibold flex-1">Awaiting Approval</span>
    <%= render(BadgeComponent.new(type: :secondary)) { @awaiting_approval.size.to_s } %>
  <% end %>
  <% awaiting_by_call = @awaiting_approval.group_by(&:call) %>
  <% if awaiting_by_call.any? %>
    <% awaiting_by_call.sort_by { |call, _| call.editing_deadline }.each do |call, proposals| %>
      <div class="p-4 border-b pb-2">
        <div class="flex flex-wrap gap-2 justify-between items-center mb-2">
          <div>
            <h6 class="mb-0"><%= link_to call.name, admin_proposals_call_proposals_path(call) %></h6>
            <small class="text-gray-500">
              Submission deadline: <%= l(call.submission_deadline, format: :longy) %>
              &middot;
              Editing deadline: <%= l(call.editing_deadline, format: :longy) %>
            </small>
          </div>
        </div>

        <% headers = [ "Show Title" ] %>
        <% headers << "Actions" if can_act %>

        <% field_sets = proposals.map do |proposal|
          fields = [ get_link(proposal, :show, link_text: proposal.show_title) ]
          if can_act
            approve_link = proposal.has_debtors ?
              get_link(proposal, :approve, query_params: redirect_param, confirm: "Approving #{proposal.show_title}", detail: "Warning: You are attempting to approve a show with debtors.\n Please type 'Ignoring Debt' to confirm", type_confirm: "Ignoring Debt") :
              get_link(proposal, :approve, query_params: redirect_param)

            fields << safe_join([
              approve_link,
              get_link(proposal, :reject, query_params: redirect_param)
            ].compact, " ")
          end
          { fields: fields }
        end %>

        <%= render "shared/table", headers: headers, field_sets: field_sets, col_widths: ["70%", "30%"] %>
      </div>
    <% end %>
  <% else %>
    <div class="p-4">
      <p class="mb-0"><em>No proposals are awaiting approval.</em></p>
    </div>
  <% end %>
<% end %>

<%= render CardComponent.new(flush: true) do |c| %>
  <% c.with_tools do %>
    <span class="text-base font-semibold flex-1">Approved (Awaiting GM Outcome)</span>
    <%= render(BadgeComponent.new(type: :secondary)) { @approved.size.to_s } %>
  <% end %>
  <% if @approved.any? %>
    <% @approved.group_by(&:call).each do |call, proposals| %>
      <div class="p-4 border-b pb-2">
        <div class="mb-2">
          <h6 class="mb-0"><%= link_to call.name, admin_proposals_call_proposals_path(call) %></h6>
          <small class="text-gray-500">
            Submission deadline: <%= l(call.submission_deadline, format: :longy) %>
            &middot;
            Editing deadline: <%= l(call.editing_deadline, format: :longy) %>
          </small>
        </div>

        <% headers = [ "Show Title" ] %>
        <% headers << "Actions" if can_act %>

        <% field_sets = proposals.map do |proposal|
          fields = [ get_link(proposal, :show, link_text: proposal.show_title) ]
          if can_act
            fields << safe_join([
              get_link(proposal, :mark_successful, query_params: redirect_param),
              get_link(proposal, :mark_unsuccessful, query_params: redirect_param)
            ].compact, " ")
          end
          { fields: fields }
        end %>

        <%= render "shared/table", headers: headers, field_sets: field_sets, col_widths: ["70%", "30%"] %>
      </div>
    <% end %>
  <% else %>
    <div class="p-4">
      <p class="mb-0"><em>No approved proposals are awaiting a GM outcome.</em></p>
    </div>
  <% end %>
<% end %>
