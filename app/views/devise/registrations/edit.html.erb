<h2>Edit <%= resource_name.to_s.humanize %></h2>

<%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
  <%= f.error_notification %>

  <div class="form-inputs">
    <%= f.input :email, required: true, autofocus: true %>

    <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
      <p>Currently waiting confirmation for: <%= resource.unconfirmed_email %></p>
    <% end %>

    <%= f.input :password, autocomplete: "off", hint: "leave it blank if you don't want to change it", required: false %>
    <%= f.input :password_confirmation, required: false %>
    <%= f.input :current_password, hint: "we need your current password to confirm your changes", required: true %>
  </div>

  <div class="form-actions mb-3">
    <%= f.button :submit, "Update", class: 'btn btn-primary' %>
  </div>
<% end %>

<hr>

<h3>Staffing Calendar</h3>

<p>Subscribe to your personal staffing calendar to see your upcoming shifts automatically in your calendar app.</p>

<% if current_user.calendar_token.present? %>
  <% webcal_url = staffing_calendar_url(token: current_user.calendar_token).sub(/\Ahttps?:\/\//, "webcal://") %>
  <% https_url  = staffing_calendar_url(token: current_user.calendar_token) %>

  <p>
    <%= link_to "Subscribe to Staffing Calendar", webcal_url, class: "btn btn-primary" %>
  </p>

  <div class="input-group mb-3" style="max-width: 600px;">
    <input type="text" class="form-control" value="<%= https_url %>" id="calendar-url" readonly>
    <button class="btn btn-outline-secondary" type="button"
            onclick="navigator.clipboard.writeText('<%= j(https_url) %>'); this.textContent='Copied!'">
      Copy link
    </button>
  </div>

  <%= calendar_instructions_for(current_user.email) %>

  <p>
    <%= link_to "Regenerate link", regenerate_calendar_token_path,
                method: :post,
                data: { confirm: "This will invalidate your current calendar link. Any calendar apps already subscribed will stop working until you re-subscribe. Continue?" },
                class: "btn btn-sm btn-outline-danger" %>
  </p>
<% else %>
  <p class="text-muted">No calendar token set yet. Edit your profile to generate one.</p>
<% end %>

<h3>Cancel my account</h3>

<p>Unhappy? <%= link_to "Cancel my account", registration_path(resource_name), data: { title: "Are you sure?" }, method: :delete %></p>
<%= link_to "Back", :back %>
