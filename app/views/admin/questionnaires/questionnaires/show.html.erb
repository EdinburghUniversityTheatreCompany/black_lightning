<% fields = {
  event: get_link(@questionnaire.event, :show),
  notify_emails: @questionnaire.notify_emails.pluck(:email).to_sentence.presence || 'No notify emails set'
} %>

<% content_for :extra_show_actions do %>
  <%= get_link @questionnaire, :answer, http_method: :get, variant: :primary %>
<% end %>

<%= render('shared/pages/show', object: @questionnaire, fields: fields) %>

<%= render CardComponent.new(title: "Questions", flush: true) do %>
  <%= render Admin::QuestionsAndAnswersComponent.new(answers: @questionnaire.answers, flush: true) %>
<% end %>
