<%# locals: () %>

<%= simple_horizontal_form_for [@editable_block] do |f| %>
  <%= render('shared/pages/form', f: f) do %>
    <%= f.input :name, hint: 'You should not change the name, unless the block is a page for about, resources, or get involved. If you still change it, the site will not be able to find the Editable Block and cannot show it where necessary.' %>

    <%= f.input :url, hint: 'The url is required to determine the location of the page for about, archives, resources, and get involved. Must NOT end with a "/".', input_html: { type: 'text' } %>

    <%= f.input :group, collection: Admin::EditableBlock.groups, include_blank: false, allow_custom_input: true, hint: "The section which the block should be displayed under in the admin site" %>

    <%= f.input :ordering, hint: 'The ordering in the subpage layer. Unused in other situations. From low to high.'%>

    <%= render "/shared/form/md_editor", f: f, field: :content, rows: 12 %>

    <% if @editable_block.persisted? %>
      <%= f.input :version_note, label: "Edit summary", hint: "Briefly describe what you changed (optional)", input_html: { maxlength: 255 } %>
    <% end %>

    <small class="d-block mb-2">
      <strong>Images</strong> can be uploaded directly via the editor toolbar (image icon).<br>
      <strong>Other files</strong> (PDFs, documents): upload via the Attachments section below, then link from the editor using <code>[link text](/attachments/attachmentname)</code>.
    </small>

    <%= render 'shared/form/sections/attachments', f: f, include_header: false %>
  <% end %>
<% end %>