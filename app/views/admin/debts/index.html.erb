<% search_fields = {
  full_name_cont:     { slug: 'defaults.name' },
  email_cont:         { slug: 'defaults.email' },
  show_in_debt_only:  { slug: 'defaults.show_in_debt_only', type: :boolean}
} %>

<% quick_actions = [] %>
<% if can?(:debt_overview, Event) %>
  <% quick_actions << link_to('Show Debt Overview', debt_overview_admin_events_path, class: 'btn btn-primary') %>
<% end %>
<% quick_actions << link_to('Bulk Debt Checker', new_admin_debt_checker_path, class: 'btn btn-secondary') %>

<%= render 'shared/pages/index', resource_class: Admin::Debt, resources: @users, content: render('index_results'),
  search_fields: search_fields, show_new_button: false, include_edit_button: false, include_link_to_item: false, quick_actions: quick_actions %>
