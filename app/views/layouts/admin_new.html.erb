<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <title><%= "#{@title} | " unless @title.nil? %>Bedlam Theatre Members</title>

  <%= vite_client_tag %>
  <%= vite_javascript_tag "admin_new" %>
  <%= vite_stylesheet_tag "admin_new.css" %>

  <%= csrf_meta_tags %>
  <%= yield :head %>

  <% if Rails.env.test? %>
    <style>*, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }</style>
  <% end %>

  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
</head>

<body class="h-full bg-gray-100 font-sans"
      data-controller="admin--sidebar konami-code form-validator select"
      data-action="keydown@window->konami-code#keyDown"
      data-konami-code-heads-value="<%= itify_head_urls.to_json %>"
      data-konami-code-pineapple-value="<%= asset_path('easter_egg/pineapple.png') %>">

  <div class="flex h-full overflow-hidden">
    <%= render Admin::SidebarComponent.new(
          nav_items: admin_navbar_items,
          current_user: current_user,
          current_path: request.fullpath
        ) %>

    <div class="flex flex-col flex-1 min-w-0 overflow-hidden">
      <%= render Admin::NavbarComponent.new(current_user: current_user) %>

      <% @header_user ||= current_user %>
      <%= content_for?(:content_header) ? yield(:content_header) :
          render(Admin::PageHeaderComponent.new(title: @title, header_badges: @header_badges)) %>

      <%= render "/layouts/alert_div" %>

      <main class="flex-1 overflow-y-auto">
        <div class="px-6 py-4">
          <%= content_for?(:content) ? yield(:content) : yield %>
        </div>

        <footer class="border-t border-gray-200 bg-white">
          <%= render "layouts/footer" %>
        </footer>
      </main>
    </div>
  </div>
</body>
</html>
