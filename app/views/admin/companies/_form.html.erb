<%# locals: () %>

<%= simple_horizontal_form_for [:admin, @company] do |f| %>
  <%= render('shared/pages/form', f: f) do %>
    <%= f.input :name %>
    <%= f.input :internal, label: 'Internal (EUTC)',
                hint: 'Tick for internal opportunities. These are shown first in listings.' %>
    <%= f.input :website, hint: 'Optional. Full URL including https://.' %>
    <%= f.input :instagram, hint: 'Optional. Instagram handle (e.g. @bedlamtheatre) or full URL.' %>
  <% end %>
<% end %>
