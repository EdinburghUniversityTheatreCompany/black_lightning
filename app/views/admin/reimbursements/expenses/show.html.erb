<p class="mb-3 text-gray-600">
  <%= link_to "← All my expenses", admin_reimbursements_expenses_path, class: "text-primary underline" %>
</p>

<%= render CardComponent.new(title: "Expense ##{@expense.auto_number}") do %>
  <div class="mb-3 flex flex-wrap items-center gap-2">
    <%= reimbursements_producer_status_badge(@expense.status) %>
    <% if @expense.editable? %>
      <%= link_to "Edit", edit_admin_reimbursements_expense_path(@expense.record_id),
            class: btn_classes(:secondary, :sm) %>
    <% end %>
  </div>

  <% if @expense.status == Reimbursements::Status::REJECTED && @expense.rejection_reason.present? %>
    <div class="mb-3"><%= render AlertComponent.new(type: :danger) do %>
      Not approved: <%= @expense.rejection_reason %>
    <% end %></div>
  <% end %>

  <dl class="grid grid-cols-2 gap-x-6 gap-y-2 text-sm sm:grid-cols-3">
    <div><dt class="text-gray-500">Amount</dt><dd class="font-medium"><%= reimbursements_money(@expense.amount) %></dd></div>
    <div><dt class="text-gray-500">Amount excl. VAT</dt><dd class="font-medium"><%= reimbursements_money(@expense.amount_excl_vat) %></dd></div>
    <div><dt class="text-gray-500">Budget</dt><dd class="font-medium"><%= @expense.budget&.name || "—" %></dd></div>
    <div><dt class="text-gray-500">Payment reference</dt><dd class="font-medium"><%= @expense.payment_reference.presence || "—" %></dd></div>
    <div><dt class="text-gray-500">Created</dt><dd class="font-medium"><%= reimbursements_date(@expense.submitted_at) %></dd></div>
    <% if @expense.payment_confirmed_date.present? %>
      <div><dt class="text-gray-500">Paid on</dt><dd class="font-medium"><%= reimbursements_date(@expense.payment_confirmed_date) %></dd></div>
    <% end %>
  </dl>

  <dl class="mt-3">
    <dt class="text-sm text-gray-500">Description</dt>
    <dd class="text-sm"><%= @expense.description.presence || "—" %></dd>
  </dl>

  <% if @expense.payee_override? %>
    <div class="mt-3 rounded border border-gray-200 p-3 text-sm">
      <p class="font-medium">Paid to a third party</p>
      <p class="text-gray-600">
        <%= @expense.effective_payee_name %> —
        <%= @expense.effective_sort_code.presence || "—" %> /
        <%= @expense.effective_account_number.presence || "—" %>
      </p>
    </div>
  <% end %>
<% end %>

<%= render CardComponent.new(title: "Receipts", html_class: "mt-4") do %>
  <%= render "receipts_gallery", expense: @expense, readonly: true %>
<% end %>
