<dialog id="<%= @id %>"
        class="rounded-lg shadow-xl bg-white p-0 w-full max-w-lg m-auto backdrop:bg-black/50"
        <%= tag.attributes(data: dialog_data) %>>
  <div class="px-4 py-3 border-b border-gray-200 flex items-center justify-between">
    <h5 class="text-base font-semibold text-gray-900"><%= @title %></h5>
    <button type="button"
            class="text-gray-400 hover:text-gray-600 text-xl leading-none font-bold"
            data-action="click->modal#close"
            aria-label="Close">&times;</button>
  </div>

  <div class="p-4">
    <%= content %>
  </div>

  <% if footer? %>
    <div class="px-4 py-3 border-t border-gray-200 flex items-center justify-between gap-2">
      <%= footer %>
    </div>
  <% end %>
</dialog>
