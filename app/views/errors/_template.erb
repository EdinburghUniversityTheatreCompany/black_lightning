<%# locals: (error_header:) %>

<div class="mx-auto">
  <%= render CardComponent.new do %>
    <%= image_tag "HAL9000.png", style: "width: 250px;", class: 'mb-3 mx-auto block', alt: "HAL 9000" %>
    <h3 class="text-danger"><b><%= error_header %></b></h3>
    <%= yield %>
  <% end %>

  <%= render AlertComponent.new(type: :danger) do %>
    <h4><b>Errors:</b></h4>
    <%= render_as_list(@error_messages, 'ul') %>

    <% if @exception_backtrace.present? && current_ability.can?(:view_details, :errors) %>
      <h4><b>Backtrace:</b></h4>
      <%= render_as_list(@exception_backtrace, 'ol') %>
    <% end %>
  <% end %>
</div>
