<%# locals: () %>

<%= simple_horizontal_form_for [:admin, @news] do |f| %>
  <%= render('shared/pages/form', f: f) do %>
    <div data-controller="slug-generator">
      <%= f.input :title, input_html: {
            id: 'event_name',
            data: { 'slug-generator-target': 'name', action: 'input->slug-generator#nameChanged' }
          } %>

      <%= render "/shared/form/md_editor", f: f, field: :body, rows: 12 %>

      <%= f.input :slug, input_html: {
            id: 'event_slug',
            data: { 'slug-generator-target': 'slug', action: 'input->slug-generator#slugChanged' }
          } %>
    </div>

    <%= f.input :publish_date, hint: 'The dashboard and frontpage will only display this news item after the publish date.' %>

    <%= f.input :show_public, hint: 'Display this news item on the publicly visible part of the website?' %>

    <%= render 'shared/form/file_field', f: f, field_name: :image %>
  <% end %>
<% end %>
