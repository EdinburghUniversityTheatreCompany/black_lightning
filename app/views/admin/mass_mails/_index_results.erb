<% headers = [:subject, :draft, :send_date] %>

<% field_sets = @mass_mails.map { |mass_mail| {
  fields: [
    mass_mail,
    bool_icon(mass_mail.draft),
    get_send_date(mass_mail)
  ] } } %>

<%= render 'shared/pages/index_results', resources: @mass_mails, resource_class: MassMail, headers: headers, field_sets: field_sets %>
