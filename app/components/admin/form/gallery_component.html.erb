<div class="gallery-form">
  <%= render(CollapsibleSectionComponent.new(title: 'Gallery', start_open: true)) do %>
    <%= render('shared/form/sections/nested_fields', 
      f: @f,
      association_name: :pictures,
      partial_name: 'picture_fields',
      container_class: 'grid grid-cols-12 gap-x-4',
      wrapper_class: 'col-span-12 lg:col-span-6 xl:col-span-4')
    %>

    <%= render 'shared/form/dropzone/dropzone_pictures' %>
  <% end %>
</div>
