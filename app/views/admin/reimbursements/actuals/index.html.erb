<p class="mb-3 text-gray-600">
  The EUSA Actuals ledger imported during reconciliation. Each row shows its nominal
  code, EUSA period, transaction date, narrative and debit/credit, plus whether it's
  been linked to an expense or an income budget. Read-only; imports happen on the
  <%= link_to "Reconcile", admin_reimbursements_reconciliation_path, class: "underline" %> page.
</p>

<% if @periods.any? %>
  <%= render CardComponent.new(title: "Filter") do %>
    <%= form_with url: admin_reimbursements_actuals_path, method: :get, class: "flex flex-wrap items-end gap-3" do %>
      <div>
        <%= label_tag :period, "EUSA period", class: "block text-sm font-medium mb-1" %>
        <%= select_tag :period,
                       options_for_select([ [ "All periods", "" ] ] + @periods.map { |p| [ p, p ] }, @period),
                       class: "border border-gray-300 rounded px-2 py-1 text-sm" %>
      </div>
      <%= submit_tag "Apply filter", class: btn_classes(:secondary, :sm) %>
      <% if @period.present? %>
        <%= link_to "Clear", admin_reimbursements_actuals_path, class: "text-sm text-gray-600 underline" %>
      <% end %>
    <% end %>
  <% end %>
<% end %>

<div class="mb-2 flex items-center justify-between gap-3">
  <p class="text-sm text-gray-600">
    <%= pluralize(@actuals.total_count, "actual") %><%= " (period #{@period})" if @period.present? %>
  </p>
  <%= link_to "Download CSV",
              admin_reimbursements_actuals_path(request.query_parameters.merge(format: :csv)),
              class: btn_classes(:secondary, :sm) %>
</div>

<% if @actuals.total_count.zero? %>
  <%= render CardComponent.new(title: @title) do %>
    <p class="py-4 text-center text-gray-600">No EUSA Actuals imported yet.</p>
  <% end %>
<% else %>
  <% headers = [ "Nominal", "Period", "Date", "Narrative", "Debit", "Credit", "Linked to" ] %>
  <% field_sets = @actuals.map do |actual|
       linked =
         if actual.linked_expense_ids.any?
           link_to(edit_admin_reimbursements_expense_edit_path(actual.linked_expense_ids.first), class: "no-underline") do
             render(BadgeComponent.new(type: :primary, pill: true).with_content("Expense"))
           end
         elsif actual.linked_budget_ids.any?
           render(BadgeComponent.new(type: :info, pill: true).with_content("Budget"))
         else
           render(BadgeComponent.new(type: :secondary, pill: true).with_content("Unlinked"))
         end
       {
         fields: [
           actual,
           content_tag(:span, actual.nominal_code.presence || "-", class: "font-mono"),
           content_tag(:span, actual.period.presence || "-", class: "font-mono"),
           reimbursements_date(actual.date),
           actual.narrative.presence || "-",
           (reimbursements_money(actual.debit) if actual.debit&.positive?),
           (reimbursements_money(actual.credit) if actual.credit&.positive?),
           linked
         ]
       }
     end %>
  <%= render "shared/pages/index_results",
        resources: @actuals, resource_class: ::Reimbursements::EusaActual,
        headers: headers, field_sets: field_sets,
        include_edit_button: false, include_link_to_item: false, include_pagination: true %>
<% end %>
