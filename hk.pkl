// dev-env standard (dev-hooks:dev-env-setup) — version tracked via DEV_ENV_VERSION in mise.toml.
amends "package://github.com/jdx/hk/releases/download/v1.46.0/hk@1.46.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.46.0/hk@1.46.0#/Builtins.pkl"

local linters = new Mapping<String, Step> {
    ["rubocop"] {
        glob = "**/*.rb"
        check = "bin/rubocop"
        fix = "bin/rubocop -A"
    }
    // --- JavaScript (eslint) ----------------------------------------------------
    // Stimulus controllers + custom lib modules (this is a Vite app — JS lives in
    // app/javascript, see CLAUDE.md). Mirrors the `pnpm lint` script and CI's lint_js job;
    // preserves the JS coverage the old overcommit EsLint hook provided.
    ["eslint"] {
        glob = List("app/javascript/controllers/**/*.js", "app/javascript/lib/**/*.js")
        check = "pnpm exec eslint app/javascript/controllers app/javascript/lib"
        fix = "pnpm exec eslint --fix app/javascript/controllers app/javascript/lib"
    }
    // --- ERB linting (herb) -----------------------------------------------------
    // HTML-aware ERB toolchain. `analyze` is pure libherb (parse errors, no network);
    // `lint` delegates to npx @herb-tools/linter (version pinned to the herb gem, needs `node`
    // — see mise.toml) and reads `.herb.yml`. Glob-gated to ERB so a Ruby-only commit skips them.
    // herb-lint is now GATING (the ERB backlog was cleared to 0 errors/warnings — see the
    // ratchet-gates work + plans/off-topic-improvements.md). herb-analyze stays ADVISORY (`|| true`)
    // only because app/views/shared/mail/_header.html.erb and _footer.html.erb are intentional
    // HTML-email FRAGMENTS (header opens the tag structure, footer closes it) that no per-file
    // parser can validate; they're excluded from herb-lint via .herb.yml, but `herb analyze` has no
    // exclude flag. herb-lint's own `parser-no-errors` rule already gates parse errors for every
    // other template, so nothing is lost.
    ["herb-analyze"] {
        glob = "**/*.erb"
        check = "bundle exec herb analyze app/ || true"
    }
    ["herb-lint"] {
        glob = "**/*.erb"
        check = "bundle exec herb lint app/"
        fix = "bundle exec herb lint app/ --fix"
    }
    // --- Schema annotations (annotaterb, auto-regenerate) -----------------------
    // Custom step: regenerate the `# == Schema Information` blocks on models when a model or
    // the schema is committed. annotaterb reads columns from the DB connection, so probe first
    // and skip cleanly (exit 0) when no dev/test DB is reachable — a fresh/un-migrated worktree
    // never blocks a commit (same pattern as database_consistency). `fix`-only (no `check`): it
    // runs on pre-commit/`fix` but is a no-op under `hk run check`, so it is never a CI gate that
    // would rewrite files in CI. annotaterb rewrites all models; with pre-commit's stash="git"
    // the staged model(s) get re-staged, and pre-existing drift elsewhere surfaces as unstaged
    // changes. Keep loop-free — hk's internal `sh` aborts on `while read` inside `$(...)`.
    ["annotate-models"] {
        glob = List("db/schema.rb", "app/models/**/*.rb")
        fix = "if bin/rails runner \"ActiveRecord::Base.connection\" >/dev/null 2>&1; then bundle exec annotaterb models; else echo 'annotaterb: no DB reachable, skipping'; fi"
    }
    // Guard against toolchain drift: Ruby/Node are pinned in mise.toml (source of truth),
    // .ruby-version/.node-version (feed CI + setup-ruby/-node), and the prod Dockerfile
    // (bakes them into the image). This is the bug that let the prod image ship Node 22
    // while everything else ran 24 — fail if they ever diverge again. Mirrors the CI
    // `versions` job (ci.yml) so pre-commit and CI agree; keep both in sync by hand.
    ["versions"] {
        glob = List("mise.toml", ".ruby-version", ".node-version", "Dockerfile")
        check = "fail=0; ruby_file=$(tr -d '[:space:]' < .ruby-version); node_file=$(tr -d '[:space:]' < .node-version); ruby_mise=$(sed -n 's/^ruby[[:space:]]*=[^\"]*\"\\([^\"]*\\)\".*/\\1/p' mise.toml); node_mise=$(sed -n 's/^node[[:space:]]*=[[:space:]]*\"\\([^\"]*\\)\".*/\\1/p' mise.toml); ruby_docker=$(sed -n 's/^ARG RUBY_VERSION=//p' Dockerfile | tr -d '[:space:]'); [ \"$ruby_file\" = \"$ruby_mise\" ] || { echo \"mise.toml ruby ($ruby_mise) != .ruby-version ($ruby_file)\"; fail=1; }; [ \"$ruby_file\" = \"$ruby_docker\" ] || { echo \"Dockerfile ARG RUBY_VERSION ($ruby_docker) != .ruby-version ($ruby_file)\"; fail=1; }; [ \"$node_file\" = \"$node_mise\" ] || { echo \"mise.toml node ($node_mise) != .node-version ($node_file)\"; fail=1; }; grep -qF 'setup_$(cut -d. -f1 < .node-version)' Dockerfile || { echo 'prod Dockerfile must derive the Node major from .node-version, not hardcode it'; fail=1; }; ! grep -q '^ARG NODE_VERSION=' Dockerfile || { echo 'remove hardcoded ARG NODE_VERSION from Dockerfile; derive it from .node-version'; fail=1; }; exit $fail"
    }
    // Shipped scripts (bin/*, script/*) must carry the executable bit IN THE GIT INDEX
    // (mode 100755): with core.fileMode=false a local chmod +x never reaches git, so
    // clones get binstubs that die with exit 126 "Permission denied". Detects scripts
    // by shebang (line 1 only) among 100644-mode index entries. Single awk on purpose:
    // hk's internal `sh` chokes on a while/read loop inside $() (kills the script at
    // the assignment even when the substitution exits 0), so keep every intermediate
    // command zero-exit. CI's lint job enforces the same rule (see ci.yml), so the
    // gates can't drift.
    ["exec-bit-scripts"] {
        check = "bad=$(git ls-files -s | awk -F'\\t' '$1 ~ /^100644/ { if ((getline line < $2) > 0 && line ~ /^#!/) print $2; close($2) }'); if [ -n \"$bad\" ]; then echo 'Shebang scripts missing the executable bit in the git index. Fix: git update-index --chmod=+x <file>'; echo \"$bad\"; exit 1; fi"
    }
    // --- Audits (dead-code + duplication) ---------------------------------------
    // Run on pre-commit too (not just `check`/CI). Duplication uses two complementary tools:
    // flay (Ruby AST/structural, advisory — exits 0, surfaces renamed clones) and jscpd
    // (token-based, polyglot — the enforcing gate that also covers JS/CSS/SCSS/ERB). debride
    // (dead methods) + flay are local `bundle exec` (fast, no network); jscpd runs via npx
    // (needs `node`, see mise.toml) and reads `.jscpd.json`. Each carries a glob, so a docs-only
    // commit skips them.
    ["debride"] {
        glob = "**/*.rb"
        // Exclude vendor (CI's bundler-cache lands gems in vendor/bundle) + other non-source dirs,
        // else debride reports every gem's source as dead code. Mirrors the CI audit job.
        check = "bundle exec debride --exclude vendor,node_modules,tmp,log ."
    }
    ["flay"] {
        glob = "**/*.rb"
        check = "bundle exec flay ."
    }
    // `-f` scopes to code formats (no config equivalent) so docs/configs aren't flagged;
    // `.jscpd.json` `ignore` globs exclude vendored/generated paths (vendor/, db/schema.rb etc.).
    // The version-cooldown policy (latest on a 4-day cooldown, floored at v5) and the offline
    // fallback live in scripts/run-jscpd.sh, shared with the CI audit job so the gates can't drift.
    ["jscpd"] {
        glob = List("**/*.rb", "**/*.erb", "**/*.js", "**/*.css", "**/*.scss")
        check = "bash scripts/run-jscpd.sh ruby,erb,javascript,typescript,css,scss,sass,vue"
    }
    // --- Security + correctness -------------------------------------------------
    // brakeman = Rails SAST (offline, gates). bundler-audit = gem CVE scan: best-effort
    // `update` refreshes the advisory DB when online (swallowed offline), then `check` gates
    // against the bundled-or-updated DB. importmap-audit scans pinned JS (importmap apps only,
    // guarded — this Vite app has no bin/importmap, so it skips). fasterer = perf advisory
    // (exits non-zero on offenses → `|| true`). database_consistency compares model
    // validations/associations to the DB schema; it needs a reachable dev/test DB, so a cheap
    // `bin/rails runner` connection probe gates when one is up and skips (exit 0) otherwise —
    // a fresh/un-migrated worktree won't block commits. Keep every command loop-free: hk's
    // internal `sh` aborts on `while read` inside `$(...)`.
    ["brakeman"] {
        glob = "**/*.rb"
        check = "bundle exec brakeman -q --no-pager --exit-on-warn"
    }
    ["bundler-audit"] {
        glob = "**/Gemfile.lock"
        check = "bundle exec bundle-audit update >/dev/null 2>&1 || true; bundle exec bundle-audit check"
    }
    ["importmap-audit"] {
        glob = "**/importmap.rb"
        check = "if [ -f bin/importmap ]; then bin/importmap audit; else echo 'no bin/importmap — skipping'; fi"
    }
    ["fasterer"] {
        glob = "**/*.rb"
        check = "bundle exec fasterer || true"
    }
    // BASELINE (dev-env setup, 2026-06): ADVISORY (`|| true`) — ~380 pre-existing findings, mostly
    // the documented legacy integer-PK schema (PrimaryKeyType, missing FKs, length constraints; see
    // CLAUDE.md › Database). Reports without blocking; drop the `|| true` to re-gate once addressed.
    ["database_consistency"] {
        glob = List("db/schema.rb", "db/structure.sql", "app/models/**/*.rb")
        check = "if bin/rails runner \"ActiveRecord::Base.connection\" >/dev/null 2>&1; then bundle exec database_consistency || true; else echo 'database_consistency: no DB reachable, skipping'; fi"
    }
    // GitHub Actions correctness (schema/typo/expression errors). hk builtin, glob-gated to
    // workflow files. -shellcheck= turns off actionlint's shellcheck-of-run: pass — the standard's
    // run: blocks deliberately word-split ($files), and real *.sh files are covered elsewhere.
    ["actionlint"] = (Builtins.actionlint) {
        check = "actionlint -shellcheck= {{ files }}"
    }
    // GitHub Actions security (credential persistence, template injection, token scope). hk builtin.
    ["zizmor"] = Builtins.zizmor
    // Secret scanning (defense-in-depth alongside fnox). hk builtin.
    ["gitleaks"] = Builtins.gitleaks
    // Block accidentally-committed large files. hk builtin.
    ["check-added-large-files"] = Builtins.check_added_large_files
}

// `check` (what `hk run check` + CI run) = the linters PLUS the full test suite. The test step is
// deliberately KEPT OUT of `linters` so it does NOT run on pre-commit: this repo's suite is ~1700
// runs / several minutes, far too slow to gate every commit. CI's dedicated `test` job (ci.yml)
// runs `bin/rails test test:system` anyway, so coverage isn't lost. Run it locally with
// `hk run check` (or `bin/rails test`). See plans/off-topic-improvements.md.
local checkSteps: Mapping<String, Step> = (linters) {
    ["test"] {
        glob = "**/*.rb"
        check = "bin/rails test"
    }
}

hooks {
    // pre-commit: linters + audits only (fast). NO full test suite — see note above.
    ["pre-commit"] {
        fix = true
        stash = "git"
        steps = linters
    }
    ["fix"] {
        fix = true
        steps = linters
    }
    ["check"] {
        steps = checkSteps
    }
}
