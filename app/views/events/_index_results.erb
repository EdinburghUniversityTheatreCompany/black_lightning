<% items = @events.collect { |event| {
  url: url_for(event),
  image: event.fetch_image,
  header: event.name,
  paragraphs: [
    { content: event.date_range(true), small: true },
    { content: event.short_blurb }
  ],
  button_text: 'View Details'
} } %>

<%= render "shared/pages/public/index_list", items: items, resources: @events, editable_block_name: @editable_block_name %>
