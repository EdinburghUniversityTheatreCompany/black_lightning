<% if @archived_staffings.any? %>
  <%= render CardComponent.new(title: "Old Positions", flush: true) do |c| %>
    <% c.with_footer do %>
      <%= paginate @archived_staffings_pagination, window: 2 %>
    <% end %>
    <%= render Admin::StaffingIndexRowComponent.new(staffings_hash: @archived_staffings, archived: true) %>
  <% end %>
<% end %>
