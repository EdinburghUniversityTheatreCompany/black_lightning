<div class="bg-white rounded border border-gray-200 mb-4 <%= @html_class %>">
  <% if render_header? %>
    <div class="px-4 py-3 border-b font-medium flex items-center <%= header_classes %>">
      <% if @title %>
        <span class="text-base font-semibold flex-1"><%= @title %></span>
      <% end %>
      <%= tools %>
    </div>
  <% end %>
  <% if @flush %>
    <%= content %>
  <% else %>
    <div class="p-4">
      <%= content %>
    </div>
  <% end %>
  <% if footer? %>
    <div class="px-4 py-3 border-t border-gray-200 bg-gray-50">
      <%= footer %>
    </div>
  <% end %>
</div>
