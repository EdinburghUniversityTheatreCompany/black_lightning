<p class="mb-3 text-gray-600">
  You can edit this claim while it's still waiting for review. Once the finance team
  picks it up, contact <%= mail_to "finance@bedlamfringe.co.uk" %> for changes.
</p>

<div data-controller="receipts-upload"
     data-receipts-upload-url-value="<%= admin_reimbursements_expense_receipts_path(@expense.record_id) %>">
  <%= render CardComponent.new(title: "Receipts") do %>
    <div class="dropzone dropzone-default mb-3 p-4 text-center"
         data-action="dragover->receipts-upload#dragover dragleave->receipts-upload#dragleave drop->receipts-upload#drop">
      <input type="file" multiple class="hidden" tabindex="-1" aria-hidden="true"
             accept="<%= Reimbursements::ExpenseForm::ALLOWED_RECEIPT_TYPES.join(',') %>"
             data-receipts-upload-target="input"
             data-action="change->receipts-upload#inputChanged">
      <div class="dropzone-msg dz-message text-gray-600">
        <h3 class="dropzone-msg-title">
          Drag a receipt here, or
          <button type="button" class="font-medium underline" data-action="receipts-upload#pick">browse for a file</button>
        </h3>
        <span class="dropzone-msg-desc text-sm">PDF or photo, max 5&nbsp;MB. It's added straight away.</span>
      </div>
    </div>
    <p class="mb-2 text-sm text-gray-600" aria-live="polite" data-receipts-upload-target="status"></p>

    <%= render "receipts_gallery", expense: @expense %>
  <% end %>
</div>

<%= render "form", form: @form, budgets: @budgets,
      url: admin_reimbursements_expense_path(@expense.record_id), method: :patch,
      submit_label: "Save changes", show_receipt_input: false %>
