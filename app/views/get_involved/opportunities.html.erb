<h1>Opportunities</h1>

<% if @editable_block %>
<div class="mb-3">
  <%= display_block(@editable_block.name, false) %>
</div>
<% end %>

<% if @opportunities.count == 0 %>
  <%= display_block("No Opportunities", false) %>
<% else %>
  <%= render CardComponent.new(flush: true) do %>
    <ul class="flex flex-col divide-y divide-gray-100 px-4">
      <% @opportunities.each do |opportunity| %>
        <li>
          <%= render OpportunityCardComponent.new(
                opportunity: opportunity,
                current_user: @current_user,
                backend_access: can?(:access, :backend),
                detailed: true) %>
        </li>
      <% end %>
    </ul>
  <% end %>
<% end %>

<div class="mb-3"></div>
