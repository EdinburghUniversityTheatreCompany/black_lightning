<%= display_block(@editable_block.name, false) %>

<form class="mt-3" data-controller="membership-checker" data-action="submit->membership-checker#submit">
  <% # BOOSTRAP NICETOHAVE: This form %>
  <div class="form-floating mb-3">
    <input type="text" class="form-control" id="membershipSearch" name="search" placeholder="Finbar the Viking" autofocus="autofocus" data-membership-checker-target="input">
    <label for="membershipSearch">Membership Number or Member Name</label>
  </div>

  <button type="submit" class="<%= btn_classes(:secondary) %> mb-3">Submit</button>
</form>

<div class="results-box"></div>
