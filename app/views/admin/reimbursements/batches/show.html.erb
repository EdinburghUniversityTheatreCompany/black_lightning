<p class="mb-3">
  <%= link_to "← Back to history", admin_reimbursements_batches_path, class: "text-info underline" %>
</p>

<%= render CardComponent.new(title: @batch.name.presence || @batch.record_id) do %>
  <dl class="grid grid-cols-[max-content_1fr] gap-x-4 gap-y-1 text-sm">
    <dt class="font-medium">Date sent</dt>
    <dd><%= @batch.date_sent&.iso8601 || "—" %></dd>
    <dt class="font-medium">EUSA draft created</dt>
    <dd><%= @batch.eusa_draft_created ? "yes" : "no" %></dd>
    <dt class="font-medium">Producers notified</dt>
    <dd><%= @batch.producer_notifications_sent ? "yes" : "no" %></dd>
    <% if @batch.sharepoint_backup_url.present? %>
      <dt class="font-medium">BACS xlsx</dt>
      <dd><%= link_to @batch.sharepoint_backup_url, @batch.sharepoint_backup_url,
                      class: "text-info underline", target: "_blank", rel: "noopener" %></dd>
    <% end %>
  </dl>

  <% if @batch.notes.present? %>
    <div class="mt-3">
      <p class="text-sm font-medium">Notes</p>
      <pre class="mt-1 whitespace-pre-wrap text-xs text-gray-600"><%= @batch.notes %></pre>
    </div>
  <% end %>
<% end %>

<%= render CardComponent.new(title: "#{@expenses.size} #{'expense'.pluralize(@expenses.size)}", html_class: "mt-4") do %>
  <% if @expenses.empty? %>
    <p class="py-2 text-gray-600">No expenses linked to this batch.</p>
  <% else %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="text-left text-gray-600 border-b border-gray-200">
          <tr>
            <th class="py-1 pr-3">#</th>
            <th class="py-1 pr-3">Payee</th>
            <th class="py-1 pr-3 text-right">Amount</th>
            <th class="py-1 pr-3">Budget</th>
            <th class="py-1 pr-3">Nominal</th>
            <th class="py-1 pr-3">Status</th>
            <th class="py-1 pr-3">Description</th>
          </tr>
        </thead>
        <tbody>
          <% @expenses.each do |expense| %>
            <tr class="border-b border-gray-100 align-top">
              <td class="py-1 pr-3"><%= expense.auto_number %></td>
              <td class="py-1 pr-3"><%= expense.effective_payee_name %></td>
              <td class="py-1 pr-3 text-right">£<%= format("%.2f", expense.amount || 0) %></td>
              <td class="py-1 pr-3"><%= expense.budget&.name %></td>
              <td class="py-1 pr-3"><%= expense.effective_nominal_code %></td>
              <td class="py-1 pr-3">
                <%= render BadgeComponent.new(type: ::Reimbursements::Status.badge_variant(expense.status), pill: true)
                              .with_content(expense.status) %>
              </td>
              <td class="py-1 pr-3"><%= expense.description %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
<% end %>
