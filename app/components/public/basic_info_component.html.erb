<h1><%= @header %></h1>

<div class="flex flex-col md:flex-row gap-4">
  <div class="w-full<%= ' md:w-2/3' if any_details? %>">
    <%# This margin only appears below md size so there is a small gap if the cards are stacked vertically. %>
    <div class="card mb-3 mb-md-0">
      <%= render "shared/image", image: @image, variant: helpers.slideshow_variant, proxy: true, image_options: { class: "card-img-top h-auto" } %>

      <% if show_card_body? %>
        <div class="card-body">
          <% if @tagline.present? %>
            <p class="card-text"><%= @tagline %></p>
          <% end %>
          <% if @admin_site %>
            <%= link_to "Download original image", helpers.active_storage_proxy_url(@image), class: "small text-muted", target: "_blank" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <% if any_details? %>
    <div class="w-full md:w-1/3">
      <div class="card h-full">
        <div class="card-body">
          <% @details.each do |detail| %>
            <h4><%= detail[:key] %></h4>
            <p><%= detail[:value] %></p>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<% if extra_content? %>
  <%= extra_content %>
<% end %>

<%# Margin here so it does not mess with the h-100 on the details card. %>
<div class="mb-3"></div>
