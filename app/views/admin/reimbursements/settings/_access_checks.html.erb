<%# locals: (checks:) %>
<%# One pass/fail row per Microsoft access probe (nil/empty renders nothing). %>
<% if checks.present? %>
  <ul class="mt-3 flex flex-col gap-2">
    <% checks.each do |check| %>
      <li class="flex items-start gap-2 text-sm">
        <%= reimbursements_access_check_badge(check.status) %>
        <span><strong><%= check.label %></strong>: <%= check.detail %></span>
      </li>
    <% end %>
  </ul>
<% end %>
