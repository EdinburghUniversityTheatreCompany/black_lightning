<% fields = {
  name: @company.name,
  internal: @company.internal,
  website: @company.website,
  slug: @company.slug
} %>

<% if @company.instagram.present? %>
  <% fields[:instagram] = { type: 'content', content: link_to(@company.instagram, @company.instagram_url, target: '_blank', rel: 'noopener') } %>
<% end %>

<% content_for :extra_show_actions do %>
  <%= get_link(Opportunity, :index, link_text: 'View Opportunities', query_params: { 'q[company_id_eq]' => @company.id }) %>
  <%= get_link(Event, :index, link_text: 'View Events', query_params: { 'q[company_id_eq]' => @company.id }) %>
<% end %>

<%= render('shared/pages/show', object: @company, fields: fields) %>
