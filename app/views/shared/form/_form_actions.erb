<%# locals: (f:, wrap_tags: true, include_index: true, submit_label: nil) %>
<% # KEEP%>
<% if wrap_tags %>
  <div class="form-actions flex flex-wrap items-center gap-2">
<% end %>

<% # There are some form actions, mainly in proposals, that don't use these. %>
<% # Please check if they need manual updates. They have been tagged with /shared/form/form_actions %>
<% if submit_label %>
  <%= f.button :submit, submit_label, class: btn_classes(:primary) %>
<% else %>
  <%= f.button :submit, class: btn_classes(:primary) %>
<% end %>

<% if f.object.present? %>
  <%= get_link f.object, :show, link_text: 'View', variant: :secondary, additional_condition: f.object.persisted?, return_link_text_if_no_permission: false %>
  <%= get_link(f.object.class, :index) if include_index %>
<% end %>

<%= yield :extra_form_actions %>
<% if wrap_tags %>
  </div>
<% end %>
