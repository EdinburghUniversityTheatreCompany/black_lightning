<% webcal_url = staffing_calendar_url(token: current_user.calendar_token).sub(/\Ahttps?:\/\//, "webcal://") %>
<% https_url  = staffing_calendar_url(token: current_user.calendar_token) %>
<%= render CardComponent.new(title: "Your Staffing Calendar") do |c| %>
  <% c.with_footer do %>
    <p class="text-gray-500 text-sm mb-0">
      Calendar invites are sent to <strong><%= current_user.calendar_email_for_invites %></strong>. You can set a different address in <%= link_to "account settings", edit_user_registration_path %>.
    </p>
  <% end %>
  <div class="input-group">
    <input type="text" class="form-control" value="<%= https_url %>" id="staffings-calendar-url" readonly autocomplete="off">
    <button class="<%= btn_classes(:secondary) %>" type="button"
            onclick="navigator.clipboard.writeText('<%= j(https_url) %>');
                     this.textContent='Copied!';
                     setTimeout(() => this.textContent='Copy', 2000)">
      Copy
    </button>
    <%= link_to "Subscribe", webcal_url, class: btn_classes(:primary) %>
    <%= button_to "Regenerate link", regenerate_calendar_token_path,
                method: :post,
                class: btn_classes(:danger),
                form: {
                  style: "display:contents",
                  data: {
                    controller: "confirm",
                    action: "submit->confirm#confirm",
                    confirm_message_value: "This will invalidate your current link. Any subscribed calendar apps will break until you re-add the new link. Continue?"
                  }
                } %>
  </div>
<% end %>

<% search_fields = {
  show_title_cont: { slug: 'defaults.show_title' },
  date_range: { type: :date_range, options: { start_date_attribute: 'start_time', end_date_attribute: 'start_time' } }
} %>
<%= render 'shared/search_form', input_fields: search_fields, columns: 2, url: admin_staffings_path %>

<%= render CardComponent.new do %>
  <%= display_block("Staffing", true) %>
<% end %>

<div id="upcoming-staffings">
  <%= render 'upcoming_results' %>
</div>

<div id="archived-staffings">
  <%= render 'archived_results' %>
</div>
