<div class="flex flex-col md:flex-row gap-4" data-controller="pretix-modal">
  <div class="w-full md:w-1/2 xl:w-2/3">
    <% carousel_config = CarouselItem::CAROUSEL_CONFIG.fetch("Home", {}) %>
    <% cache [ @carousel_events, @standard_carousel_items ] do %>
      <%= render Public::CarouselComponent.new(
            carousel_items: combine_events_with_carousel_items(@carousel_events, @standard_carousel_items),
            aspect_ratio: carousel_config[:aspect_ratio]&.join("/"),
            fit_mode: carousel_config.fetch(:fit_mode, "cover")) %>
    <% end %>

    <%= render CardComponent.new(title: "What's On", html_class: "mt-3") do %>
      <%# Cache key is the @events AR collection; changes to pretix_shown/pretix_slug bust it correctly %>
      <% cache @events do %>
        <% if @events.empty? %>
          <%= display_block("Home - No Events On", false) %>
        <% else %>
          <% items = @events.collect { |event|
            buttons = tag.div(class: "flex gap-2 flex-wrap") do
              concat link_to('View Details', event, class: btn_classes(:primary))
              if event.pretix_shown?
                concat tag.button("Buy Tickets",
                  class: btn_classes(:success),
                  data: { action: "click->pretix-modal#open",
                          pretix_modal_slug_param: event.pretix_slug,
                          pretix_modal_name_param: event.name })
              end
            end
            { event: event, paragraphs: [
              { content: event.date_and_price, small: true },
              { content: event.short_blurb },
              { content: buttons, class: 'mt-auto' }
            ] }
          } %>
          <%= render('shared/pages/public/events_grid', items: items, col_size: 8) %>
        <% end %>
      <% end %>
    <% end %>
  </div>

  <div class="w-full md:w-1/2 xl:w-1/3">
    <%= render "static/opportunities_widget", home_opportunities: @home_opportunities %>

    <%= render CardComponent.new(title: "News", flush: true) do |c| %>
      <% c.with_footer do %>
        <%= link_to 'Read all news →', news_index_path %>
      <% end %>
      <ul class="flex flex-col">
        <li class="list-row">
          <%= display_block("Home - News", false) %>
        </li>
        <% cache @news do %>
          <% @news.each do |news_item| %>
            <li class="list-row">
              <h5 class="text-base font-semibold"><%= link_to news_item.title, news_path(news_item) %></h5>

              <p class="block mb-2"><small class="text-gray-500"><%= l(news_item.publish_date, format: :longy) %> by <%= news_item.author.name %></small></p>

              <p class="block mb-2"><%= render_plain(news_item.preview) %></p>
            </li>
          <% end %>
        <% end %>
      </ul>
    <% end %>
  </div>

  <%= render "shared/pretix_modal" %>
</div>
