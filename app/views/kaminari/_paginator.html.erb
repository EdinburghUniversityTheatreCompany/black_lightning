<%# locals: (paginator:, current_page: nil, per_page: nil, remote: nil, total_pages: nil, window: nil, left: nil, right: nil) %>

<%= paginator.render do %>
  <nav aria-label="Page Navigation" class="mb-1">
    <ul class="flex gap-1 list-none m-0 <%= 'ml-auto' if @admin_site %>">
      <%= first_page_tag %>
      <%= prev_page_tag %>

      <li>
        <span>Page: </span>
      </li>
      <li>
        <%= tag.input type: "number", class: "-mt-1 w-12 h-[1.95rem] text-center text-primary bg-white border border-primary rounded px-0 shadow-none cursor-text placeholder:text-primary placeholder:opacity-60 [appearance:textfield] [-moz-appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none", value: current_page, min: 1, max: total_pages, data: { controller: "page-jump", action: "keydown.enter->page-jump#jump change->page-jump#jump" }, autocomplete: "off" %>
      </li>
      <li>
        <span> of <%= total_pages %></span>
      </li>
      <%= next_page_tag %>
      <%= last_page_tag %>
    </ul>
  </nav>
<% end %>
