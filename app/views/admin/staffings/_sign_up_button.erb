<%# locals: (job:) %>

<input type="hidden" class="staffing_job_json" value="<%= job.to_json %>" >
<% sign_up_text = '<i class="fas fa-edit" aria-hidden=”true”></i> Sign Up'.html_safe %>

<% date = l job.staffable.start_time, format: :long %>
<%= button_to sign_up_text, admin_staffing_sign_up_path(job), method: :put,
            class: "btn btn-secondary staffing-sign-up",
            data: { title: "Confirm Staffing", confirm: "Confirm staffing as #{job.name} for #{job.staffable.show_title} on #{date}", job_id: job.id },
            form: {
              data: {
                controller: "staffing-signup",
                action: "submit->staffing-signup#signUp",
                staffing_signup_job_id_value: job.id
              }
            } %>
