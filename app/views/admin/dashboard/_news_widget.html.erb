<%# locals: () %>

<% current_news = News.accessible_by(current_ability).order('publish_date DESC').current.first(4) %>

<% if current_news.empty? %>
  <p>There is no news.</p>
<% else %>
  <ul class="list-group list-group-flush">
    <% current_news.each do |news| %>
      <li class="list-group-item">
        <p class="mb-1"><%= link_to news.title, admin_news_path(news) %> <%= content_tag(:span, "Members", class: "badge bg-important") unless news.show_public %></p>
        <p class="text-muted text-sm mb-0 line-clamp-2"><%= truncate_markdown(news.body, 300) %></p>
      </li>
    <% end %>
  </ul>
<% end %>
