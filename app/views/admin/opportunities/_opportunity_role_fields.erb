<%# locals: (f:, dynamic: nil) %>

<div data-controller="department-suggest"
     data-department-suggest-departments-value="<%= Department.suggestions.to_json %>">
  <%= render '/shared/form/inline_fields_for_template',
      f: f,
      div_class_additions: 'opportunity_role',
      fields: [
          { field:    f.hidden_field(:id) +
                      f.hidden_field(:ordering, data: { display_order: true }) +
                      content_tag(:span, "⠿", data: { sortable_handle: true }, style: "cursor: grab; font-size: 1.2rem; color: #aaa;"),
                      col_modifier: 'auto' },
          { field: f.input(:position, placeholder: "Position (e.g. Stage Manager)", wrapper: :inline_form,
                      input_html: { data: { department_suggest_target: "position", action: "input->department-suggest#positionChanged" } }) },
          { field: f.input(:department_name, as: :select, label: false,
                      collection: Department.order(:ordering).pluck(:name),
                      allow_custom_input: true, include_blank: true, wrapper: :inline_form,
                      input_html: { data: { department_suggest_target: "department", action: "change->department-suggest#departmentChanged" } }) },
          { field: f.input(:note, placeholder: "Optional note", wrapper: :inline_form) },
          { field: link_to_remove(f), col_modifier: 'auto' },
  ] %>
</div>
