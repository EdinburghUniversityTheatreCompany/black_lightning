<%# locals: (items:, col_size:, link_to_admin_events: false) %>

<% amount_of_events = items.size %>

<% if amount_of_events > 0 %>
  <% if col_size == 8 %>
    <%# If there are 4 events, 2x2 is nicer than 3x1 + 1 %>
    <% amount_of_events = 2 if amount_of_events == 4 %>
    <% grid_class = case [3, amount_of_events].min
      when 1 then "grid grid-cols-1 gap-3"
      when 2 then "grid grid-cols-1 md:grid-cols-2 gap-3"
      else        "grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3"
      end %>
  <% else %>
    <% grid_class = case [4, amount_of_events].min
      when 1 then "grid grid-cols-1 gap-3"
      when 2 then "grid grid-cols-1 sm:grid-cols-2 gap-3"
      when 3 then "grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3"
      else        "grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3"
      end %>
  <% end %>

  <div class="<%= grid_class %>">
    <% items.each do |item| %>
      <div class="flex flex-col">
        <%= render CardComponent.new(html_class: "h-full", flush: true) do %>
          <% url = link_to_admin_events ? [:admin, item[:event]] : item[:event] %>
          <%= link_to url do %>
            <%= render 'shared/image', image: item[:event].fetch_image, variant: medium_variant, proxy: true, image_options: { class: 'block w-full h-auto rounded-t' } %>
          <% end %>

          <div class="p-4 flex flex-col">
            <%= link_to(item[:event].name_and_author, url, class: 'text-base font-semibold') %>

            <%= render('shared/pages/public/partials/card_paragraphs', paragraphs: item[:paragraphs]) %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
