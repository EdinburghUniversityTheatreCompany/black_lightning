<%# locals: (event:, event_type:) %>

<% if event.end_date.present? && event.end_date < Date.current %>
  <%= render AlertComponent.new(type: :info) do %>
    <i class=”fa-solid fa-circle-info fa-large” aria-hidden=”true”></i>
    This <%= event_type %> finished on <%= l event.end_date, format: :longy %>, and this page is being kept for archival purposes only.
  <% end %>
<% end %>
