<%# locals: (event:) %>

<div class="flex flex-col md:flex-row gap-4">
  <div class="w-full<%= ' md:w-2/3' if event.team_members.any? %>">
    <div class="card mb-3 mb-md-0">
      <div class="card-header">
        <h4 class="card-title">Description</h4>
      </div>
      <div class="card-body">
        <%= render_markdown event.publicity_text %>

        <% if event.pretix_shown %>
          <%= render 'shared/pretix_widget', event: event %>
        <% end %>

        <% if event.content_warnings.present? %>
          <div class="mt-4">
            <%= render CollapsibleSectionComponent.new(title: 'Content Warnings') do %>
              <%= render_markdown event.content_warnings %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <% if event.team_members.any? %>
    <div class="w-full md:w-1/3">
      <div class="card h-full">
        <div class="card-header">
          <h4 class="card-title">Cast and Crew</h4>
        </div>
        <div class="card-body">
          <%= render '/shared/admin_show_team_members', team_members: event.team_members.ordered %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<% # Margin here so it does not mess with the h-100 on the cards. %>
<div class="mb-3"></div>
