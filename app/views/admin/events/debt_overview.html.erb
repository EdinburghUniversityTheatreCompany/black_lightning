<div class="card mb-3">
  <div class="card-header">
    <h5 class="card-title mb-0">Debt Overview</h5>
  </div>
  <div class="card-body">
    <p class="text-gray-500 mb-2">
      Shows in the current academic year and future. Color-coded to help identify which shows need debt configuration.
    </p>
    <div class="mb-0">
      <%= render(BadgeComponent.new(type: :warning)) { "Yellow" } %> = Has tags with debt recommendations but no debts configured<br>
      <%= render(BadgeComponent.new(type: :danger)) { "Red" } %> = Has debts configured that don't match tag recommendations<br>
      <%= render(BadgeComponent.new(type: :success)) { "Green" } %> = Debts match tag recommendations
    </div>
  </div>
</div>

<div class="card">
  <div class="card-body p-0">
    <% if @shows.empty? %>
      <div class="p-4 rounded border m-3 mb-0 bg-info/10 border-info/30 text-info">
        No shows found in the current academic year or future.
      </div>
    <% else %>
      <div class="table-responsive">
        <table class="table table-striped table-hover mb-0">
          <thead>
            <tr>
              <th>Show</th>
              <th>Dates</th>
              <th>Tags</th>
              <th>Maintenance Debts</th>
              <th>Staffing Debts</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @shows.each do |show| %>
              <tr class="<%= debt_status_row_class(show) %>">
                <td>
                  <%= get_link show, :show %>
                </td>
                <td>
                  <%= show.date_range(true, :short) %>
                </td>
                <td>
                  <% if show.event_tags.any? %>
                    <% show.event_tags.each do |tag| %>
                      <%= render(BadgeComponent.new(type: :secondary)) { tag.name } %>
                    <% end %>
                  <% else %>
                    <span class="text-gray-500">No tags</span>
                  <% end %>
                </td>
                <td>
                  <% if show.maintenance_debt_amount.present? %>
                    <strong><%= show.maintenance_debt_amount %></strong>
                    <% if show.maintenance_debt_start.present? %>
                      (due <%= show.maintenance_debt_start.strftime("%d %b %y") %>)
                    <% end %>
                  <% else %>
                    <span class="text-gray-500">Not configured</span>
                  <% end %>
                </td>
                <td>
                  <% if show.staffing_debt_amount.present? %>
                    <strong><%= show.staffing_debt_amount %></strong>
                    <% if show.staffing_debt_start.present? %>
                      (due <%= show.staffing_debt_start.strftime("%d %b %y") %>)
                    <% end %>
                  <% else %>
                    <span class="text-gray-500">Not configured</span>
                  <% end %>
                </td>
                <td>
                  <%= link_to 'Configure', admin_show_path(show, anchor: 'debt_settings'), class: btn_classes(:primary, :sm) %>
                </td>
              </tr>
              <% if show_debt_recommendation_details?(show) %>
                <tr class="<%= debt_status_row_class(show) %>">
                  <td colspan="6" class="small">
                    <em>Tag recommendations:
                      <% show.tag_debt_recommendations.each do |rec| %>
                        <%= rec[:tag_name] %>: <%= rec[:maintenance] || 0 %> maintenance, <%= rec[:staffing] || 0 %> staffing &nbsp;
                      <% end %>
                    </em>
                  </td>
                </tr>
              <% end %>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>
</div>
