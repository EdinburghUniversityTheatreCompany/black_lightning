<%# locals: (home_opportunities:) %>
<% cache home_opportunities do %>
  <%= render CardComponent.new(title: "Opportunities", flush: true) do |c| %>
    <% c.with_footer do %>
      <div class="flex justify-between items-center">
        <%= link_to "View all opportunities →", get_involved_opportunities_path %>
        <% if can?(:create, Opportunity) %>
          <%= link_to "Submit an Opportunity", new_get_involved_opportunity_path, class: btn_classes(:primary, :sm) %>
        <% end %>
      </div>
    <% end %>
    <% if home_opportunities.empty? %>
      <div class="p-4">
        <%= display_block("No Opportunities", false) %>
      </div>
    <% else %>
      <ul class="flex flex-col">
        <% home_opportunities.each do |opportunity| %>
          <li class="list-row">
            <h5 class="text-base font-semibold mb-1">
              <%= link_to opportunity.title, get_involved_opportunities_path %>
            </h5>
            <p class="block mb-1">
              <small class="text-gray-500">Expires <%= opportunity.expiry_date.strftime("%-d %B %Y") %></small>
            </p>
            <p class="block mb-2">
              <%= truncate_markdown(opportunity.description, 100) %>
            </p>
          </li>
        <% end %>
      </ul>
    <% end %>
  <% end %>
<% end %>
