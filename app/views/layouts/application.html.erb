<!DOCTYPE html>
<html lang="en">
  <%# Include the opengraph namespaces: %>
  <head prefix="og: http://ogp.me/ns# fb: http://ogp.me/ns/fb# website: http://ogp.me/ns/website#">
  <meta charset="UTF-8">

  <title><%= "#{@title} | " unless @title.nil? %>Bedlam Theatre</title>

  <%= vite_client_tag %>
  <%# Force reload of the page if these tags change so that we don't persist the wrong JavaScript or css when transitioning from public to admin or vice-versa. %>
  <%= vite_javascript_tag "application", "data-turbo-track": "reload" %>
  <%= vite_stylesheet_tag "application.scss", "data-turbo-track": "reload" %>

  <%= csrf_meta_tags %>

  <%= yield :head %>

  <%= meta_tags(@meta).html_safe %>
</head>

<body data-controller="konami-code form-validator select"
      data-action="keydown@window->konami-code#keyDown"
      data-konami-code-heads-value="<%= itify_head_urls.to_json %>"
      data-konami-code-pineapple-value="<%= asset_path('easter_egg/pineapple.png') %>">
  <%= render "layouts/header" %>

  <div class="container">
    <%= render "layouts/ie_notice" %>

    <%= render 'layouts/alert_div' %>

    <%= content_for?(:content) ? yield(:content) : yield %>
  </div>

  <%= render "layouts/footer" %>
</body>
</html>
