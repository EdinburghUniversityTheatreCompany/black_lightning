<%# locals: (header:, image:, details: nil, tagline: nil) %>
<div class="row">
  <div class="col">
    <h1><%= header %></h1>
  </div>
</div>

<div class="row">
  <div class="col<%= '-md-8' if details.any? %>">
    <%# This margin only appears below md size so there is a small gap if the cards are stacked vertically. %>
    <div class="card mb-3 mb-md-0">
      <%= render 'shared/image', image: image, variant: slideshow_variant, proxy: true, image_options: { class: 'card-img-top h-auto' } %>

      <% if tagline.present? || @admin_site %>
        <div class="card-body">
          <% if tagline.present? %>
            <p class="card-text"><%= tagline %></p>
          <% end %>
          <% if @admin_site %>
            <%= link_to "Download original image", active_storage_proxy_url(image), class: "small text-muted", target: "_blank" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <% if details.any? %>
    <div class="col-md-4">
      <div class="card h-100">
        <div class="card-body">
          <% details.each do |detail| %>
            <h4><%= detail[:key] %></h4>
            <p><%= detail[:value] %></p>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<%# Margin here so it does not mess with the h-100 on the details card. %>
<div class="mb-3"></div>
