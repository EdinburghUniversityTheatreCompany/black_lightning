<%= render('shared/quick_actions_card') do %>
  <%= link_to @cancel_text, @cancel_path, class: ButtonComponent.classes_for(variant: :secondary) %>
<% end %>

<div class="grid grid-cols-1 md:grid-cols-2 gap-x-4">
  <div>
    <%= render CardComponent.new(title: "Option 1: Paste Data") do %>
      <%= form_with url: @preview_path, method: :post, local: true do |f| %>
        <p class="text-gray-500">Paste tab-separated data from Excel/spreadsheet. Expected columns:</p>
        <span class="font-monospace block mb-3"><%= @columns_description %></span>

        <%= f.text_area :paste_data, rows: 15, class: "form-control font-monospace",
            placeholder: @placeholder_text %>

        <div class="mt-3">
          <%= f.submit "Preview Import", class: ButtonComponent.classes_for(variant: :primary) %>
        </div>
      <% end %>
    <% end %>
  </div>

  <div>
    <%= render CardComponent.new(title: "Option 2: Upload XLSX") do %>
      <%= form_with url: @preview_path, method: :post, local: true, multipart: true do |f| %>
        <p class="text-gray-500">Upload an Excel file (.xlsx) with the same column structure.</p>

        <div class="mb-3">
          <%= f.file_field :xlsx_file, accept: ".xlsx", class: "form-control" %>
        </div>

        <div class="mt-3">
          <%= f.submit "Preview Import", class: ButtonComponent.classes_for(variant: :primary) %>
        </div>
      <% end %>
    <% end %>

    <%= render CardComponent.new(title: "How It Works", html_class: "mt-4") do %>
      <%= content %>
    <% end %>
  </div>
</div>
