<div class="flex flex-wrap items-center justify-between gap-2">
  <h1 class="mb-0">My Reimbursements</h1>
  <div class="flex items-center gap-2">
    <%= link_to "Refresh", admin_reimbursements_expenses_path(refresh: 1), class: btn_classes(:secondary, :sm) %>
    <%= link_to "New expense", new_admin_reimbursements_expense_path, class: btn_classes(:primary) %>
  </div>
</div>

<p class="mt-2 text-gray-600">
  Expenses you submit are reviewed by the finance team, batched to EUSA, and paid into
  your bank account. You can also email a receipt to
  <%= mail_to Reimbursements::CostCentre.default.mailbox %> and finish the claim here.
</p>

<% if current_person.nil? || !current_person.bank_details? %>
  <div class="my-3 rounded border border-warning/40 bg-warning/10 p-3">
    We don't have your bank details yet — you can submit expenses, but they can't be
    approved until you
    <%= link_to "add your payment details", edit_admin_reimbursements_payment_details_path, class: "font-medium underline" %>.
  </div>
<% end %>

<% if @expenses.empty? %>
  <div class="my-5 rounded border border-gray-200 p-5 text-center text-gray-600">
    No expenses yet. <%= link_to "Submit your first one", new_admin_reimbursements_expense_path, class: "font-medium underline" %> —
    upload the receipt and we'll fill in most of the form for you.
  </div>
<% else %>
  <div class="my-3 grid gap-3">
    <% @expenses.each do |expense| %>
      <%= render CardComponent.new(html_class: "reimbursements-expense") do %>
        <div class="flex flex-wrap items-start justify-between gap-2">
          <div>
            <div class="flex items-center gap-2">
              <%= render BadgeComponent.new(type: Reimbursements::Status.badge_variant(expense.status)) do %>
                <%= expense.status %>
              <% end %>
              <% if expense.needs_completion? %>
                <%= render BadgeComponent.new(type: :warning, pill: true) do %>
                  Needs completion
                <% end %>
              <% end %>
              <span class="font-medium"><%= expense.description.presence || "(no description yet)" %></span>
            </div>
            <div class="mt-1 text-sm text-gray-600">
              <%= expense.budget ? expense.budget.name : "No budget yet" %>
              <% if expense.submitted_at %>
                · submitted <%= expense.submitted_at.to_date.to_fs(:rfc822) %>
              <% end %>
              <% if expense.receipts.any? %>
                · <%= pluralize(expense.receipts.size, "receipt") %>
              <% end %>
            </div>
          </div>
          <div class="text-right">
            <div class="text-lg font-semibold">
              <%= expense.amount ? number_to_currency(expense.amount, unit: "£") : "—" %>
            </div>
            <% if expense.editable? %>
              <%= link_to "Edit", edit_admin_reimbursements_expense_path(expense.record_id), class: btn_classes(:secondary, :sm) %>
            <% end %>
          </div>
        </div>

        <% if expense.status == Reimbursements::Status::REJECTED && expense.rejection_reason.present? %>
          <div class="mt-2 rounded border border-danger/40 bg-danger/10 p-2 text-sm">
            <span class="font-medium">Rejected:</span> <%= expense.rejection_reason %>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>
<% end %>
