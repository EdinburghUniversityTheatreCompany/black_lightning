<%# locals: () %>

<%= simple_horizontal_form_for [:admin, @opportunity] do |f| %>
  <%= render('shared/pages/form', f: f) do %>
    <% if @opportunity.approved %>
      <small>
        <% if can? :approve, @opportunity %>
          Note: Because you can approve opportunities, this opportunity will stay approved after editing it.
        <% else %>
          Note: Editing this opportunity will result in it being hidden until it is re-approved.
        <% end %>
      </small>
    <% end %>
    
    <%= f.input :title %>

    <%= f.input :expiry_date %>
    <%= f.input :email_visibility,
        as: :select,
        collection: Opportunity.email_visibilities.keys.map { |k| [k.humanize, k] },
        hint: "Controls who can see a contact email for this opportunity. 'Members only' shows it to logged-in members with backend access." %>

    <%= f.input :contact_email,
        hint: "Optional. If left blank and email visibility is enabled, your account email (#{current_user.email}) will be shown instead." %>

    <%= render Admin::MdEditorComponent.new(f: f, field: :description, rows: 12) %>
  <% end %>
<% end %>
