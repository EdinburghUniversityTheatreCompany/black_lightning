<%= render('shared/quick_actions_card') do %>
  <%= link_to "Back to History",
      admin_editable_block_version_histories_path(@parent_record),
      class: btn_classes(:secondary) %>
  <%= get_link @parent_record, :show, link_text: "View", variant: :secondary %>
<% end %>

<%= render CardComponent.new do %>
  <h5>
    Version by <%= version_author_name(@version) %>
    on <%= @version.created_at.strftime("%d %B %Y, %H:%M") %>
  </h5>

  <% if @version.version_note.present? %>
    <p class="text-gray-500"><em><%= @version.version_note %></em></p>
  <% end %>

  <hr>

  <% if @diff.any? %>
    <% @diff.each do |attribute, (old_val, new_val)| %>
      <h6><%= attribute.titleize %></h6>

      <% if old_val.length > 80 || new_val.length > 80 %>
        <div class="diff-container">
          <%= Diffy::Diff.new(old_val + "\n", new_val + "\n", include_plus_and_minus_in_html: true, include_diff_info: false).to_s(:html).html_safe %><%# herb:disable erb-no-unsafe-raw %>
        </div>
      <% else %>
        <p>
          <del class="text-danger"><%= old_val.presence || "(empty)" %></del>
          &rarr;
          <ins class="text-success"><%= new_val.presence || "(empty)" %></ins>
        </p>
      <% end %>
    <% end %>
  <% else %>
    <p class="text-gray-500">No attribute changes detected for this version.</p>
  <% end %>
<% end %>
