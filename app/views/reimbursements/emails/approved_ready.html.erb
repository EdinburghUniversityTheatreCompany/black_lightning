<table border="1" cellspacing="0" cellpadding="4" style="border-collapse: collapse; font-family: sans-serif; margin-bottom: 1em;">
  <thead style="background-color: #f0f0f0;">
    <tr>
      <th scope="col">#</th><th scope="col">Payee</th><th scope="col">Amount</th>
      <th scope="col">Budget</th><th scope="col">Description</th>
    </tr>
  </thead>
  <tbody>
    <% @expenses.each do |expense| %>
      <tr>
        <td>#<%= expense[:auto_number] %></td>
        <td><%= expense[:payee_name] %></td>
        <td><%= reimbursements_money(expense[:amount]) %></td>
        <td><%= expense[:budget_name] %></td>
        <td><%= expense[:description] %></td>
      </tr>
    <% end %>
  </tbody>
  <tfoot style="background-color: #f0f0f0; font-weight: bold;">
    <tr><td colspan="2">Total</td><td><%= reimbursements_money(@total) %></td><td colspan="2"></td></tr>
