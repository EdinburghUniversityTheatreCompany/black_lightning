<p class="mb-3 text-gray-600">
  Past BACS submissions, most recent first. Reopening a batch reverts its expenses to Approved and
  deletes the batch so you can add or remove expenses and rebuild it — producers already notified
  won't be emailed again. A batch with any Paid expense can't be reopened.
</p>

<p class="mb-4">
  <%= link_to "Build a new batch", new_admin_reimbursements_batch_path, class: btn_classes(:primary, :sm) %>
</p>

<% if @batches.empty? %>
  <%= render AlertComponent.new(type: :info) do %>
    No batches yet. Build one from the Build Batch page.
  <% end %>
<% else %>
  <div class="flex flex-col gap-2">
    <% @batches.each do |batch| %>
      <% expenses = @expenses_by_batch.fetch(batch.record_id, []) %>
      <% batch_total = expenses.sum { |expense| expense.amount || 0 } %>
      <% has_paid = expenses.any? { |expense| expense.status == ::Reimbursements::Status::PAID } %>
      <%= render CardComponent.new do %>
        <div class="flex flex-wrap items-center gap-x-4 gap-y-1">
          <span class="font-medium"><%= batch.date_sent&.iso8601 || "—" %></span>
          <span class="text-gray-600 grow"><%= batch.name.presence || batch.record_id %></span>
          <span class="text-sm"><%= expenses.size %> <%= "expense".pluralize(expenses.size) %></span>
          <span class="text-sm font-medium">£<%= format("%.2f", batch_total) %></span>
          <% if batch.eusa_draft_created %>
            <%= render BadgeComponent.new(type: :success, pill: true).with_content("Draft created") %>
          <% end %>
          <%= link_to "Detail", admin_reimbursements_batch_path(batch.record_id), class: btn_classes(:secondary, :sm) %>
        </div>

        <div class="mt-2">
          <% if has_paid %>
            <p class="text-sm text-warning">
              Has Paid expenses — reconciled payments can't be reverted, so this batch can't be reopened.
            </p>
          <% elsif expenses.any? %>
            <%= form_with url: reopen_admin_reimbursements_batch_path(batch.record_id), method: :post do %>
              <%= submit_tag "Reopen for rebuild", class: btn_classes(:danger, :sm),
                             data: { turbo_confirm: "Revert #{expenses.size} #{'expense'.pluralize(expenses.size)} " \
                                                    "to Approved and delete this batch?" } %>
            <% end %>
          <% else %>
            <p class="text-sm text-gray-500">No linked expenses to reopen.</p>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>
