<%= render(Admin::CardComponent.new(title: "Debt Summary", variant: card_variant)) do %>
  <div class="flex items-center gap-1 mb-3">
    <p class="text-sm text-gray-700 mb-0">
      <span class="font-semibold"><%= @user.name(@current_user) %></span> is currently
    </p>
    <% if @user.in_debt %>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800"><%= status_label %></span>
    <% elsif has_upcoming? %>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800"><%= status_label %></span>
    <% else %>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800"><%= status_label %></span>
    <% end %>
  </div>

  <% unless check_only? %>
    <div class="grid grid-cols-2 gap-4 mb-4">
      <div class="border border-gray-200 rounded p-3">
        <div class="flex items-center justify-between mb-2">
          <h6 class="text-sm font-semibold text-gray-700 mb-0">Staffing Debts</h6>
          <%= link_to "View all", helpers.admin_staffing_debts_path(user_id: @user.id), class: "text-xs text-blue-600 hover:underline" %>
        </div>
        <div class="flex gap-6">
          <div>
            <div class="text-2xl font-bold text-gray-900"><%= @user.admin_staffing_debts.unfulfilled.count %></div>
            <div class="text-xs text-gray-500">Unfulfilled</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-gray-900"><%= @user.staffing_jobs_unlinked_count %></div>
            <div class="text-xs text-gray-500">Unlinked jobs</div>
          </div>
        </div>
      </div>

      <div class="border border-gray-200 rounded p-3">
        <div class="flex items-center justify-between mb-2">
          <h6 class="text-sm font-semibold text-gray-700 mb-0">Maintenance Debts</h6>
          <%= link_to "View all", helpers.admin_maintenance_debts_path(user_id: @user.id), class: "text-xs text-blue-600 hover:underline" %>
        </div>
        <div class="flex gap-6">
          <div>
            <div class="text-2xl font-bold text-gray-900"><%= @user.admin_maintenance_debts.unfulfilled.count %></div>
            <div class="text-xs text-gray-500">Unfulfilled</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-gray-900"><%= @user.maintenance_attendances_unlinked_count %></div>
            <div class="text-xs text-gray-500">Unlinked attendances</div>
          </div>
        </div>
      </div>
    </div>

    <% if past_staffing.any? || past_maintenance.any? %>
      <h6 class="text-sm font-semibold text-gray-700 mb-2">Unfulfilled Past Debts</h6>
      <div class="border border-gray-200 rounded overflow-hidden mb-4">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 text-gray-600 text-xs uppercase">
            <tr>
              <th class="px-3 py-2 text-left">Type</th>
              <th class="px-3 py-2 text-left">Show</th>
              <th class="px-3 py-2 text-left">Due By</th>
              <th class="px-3 py-2 text-left">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% past_staffing.includes(:show).each do |debt| %>
              <tr class="<%= tailwind_row_class(debt.css_class) %>">
                <td class="px-3 py-2"><span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800">Staffing</span></td>
                <td class="px-3 py-2"><%= helpers.get_link(debt.show, :show) %></td>
                <td class="px-3 py-2"><%= debt.due_by %></td>
                <td class="px-3 py-2"><%= helpers.formatted_status_for_debt(debt) %></td>
              </tr>
            <% end %>
            <% past_maintenance.includes(:show).each do |debt| %>
              <tr class="<%= tailwind_row_class(debt.css_class) %>">
                <td class="px-3 py-2"><span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-purple-100 text-purple-800">Maintenance</span></td>
                <td class="px-3 py-2"><%= helpers.get_link(debt.show, :show) %></td>
                <td class="px-3 py-2"><%= debt.due_by %></td>
                <td class="px-3 py-2"><%= helpers.formatted_status_for_debt(debt) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>

    <% if has_upcoming? %>
      <h6 class="text-sm font-semibold text-gray-700 mb-2">Upcoming Debts</h6>
      <div class="border border-gray-200 rounded overflow-hidden mb-4">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 text-gray-600 text-xs uppercase">
            <tr>
              <th class="px-3 py-2 text-left">Type</th>
              <th class="px-3 py-2 text-left">Show</th>
              <th class="px-3 py-2 text-left">Due By</th>
              <th class="px-3 py-2 text-left">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% upcoming_staffing.includes(:show).each do |debt| %>
              <tr class="<%= tailwind_row_class(debt.css_class) %>">
                <td class="px-3 py-2"><span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800">Staffing</span></td>
                <td class="px-3 py-2"><%= helpers.get_link(debt.show, :show) %></td>
                <td class="px-3 py-2"><%= debt.due_by %></td>
                <td class="px-3 py-2"><%= helpers.formatted_status_for_debt(debt) %></td>
              </tr>
            <% end %>
            <% upcoming_maintenance.includes(:show).each do |debt| %>
              <tr class="<%= tailwind_row_class(debt.css_class) %>">
                <td class="px-3 py-2"><span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-purple-100 text-purple-800">Maintenance</span></td>
                <td class="px-3 py-2"><%= helpers.get_link(debt.show, :show) %></td>
                <td class="px-3 py-2"><%= debt.due_by %></td>
                <td class="px-3 py-2"><%= helpers.formatted_status_for_debt(debt) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>

    <% if past_staffing.empty? && past_maintenance.empty? && !has_upcoming? %>
      <p class="text-sm text-gray-500">No unfulfilled or upcoming debts.</p>
    <% end %>
  <% end %>
<% end %>
