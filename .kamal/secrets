# Secrets defined here are available for reference under registry/password, env/secret, builder/secrets,
# and accessories/*/env/secret in config/deploy.yml. All secrets should be pulled from either
# password manager, ENV, or a file. DO NOT ENTER RAW CREDENTIALS HERE! This file needs to be safe for git.
MASTER_KEY_FILE="config/credentials/master.key"
if [ -f "$MASTER_KEY_FILE" ]; then
  RAILS_MASTER_KEY=$(cat "$MASTER_KEY_FILE")
elif command -v bw &>/dev/null; then
  SECRETS=$(kamal secrets fetch --adapter bitwarden --account it@bedlamtheatre.co.uk Black_Lightning_Production_Master_Key)
  RAILS_MASTER_KEY=$(kamal secrets extract Black_Lightning_Production_Master_Key $SECRETS)
else
  echo "ERROR: Rails master key not found. Either:" >&2
  echo "  1. Create config/credentials/master.key locally with the master.key from the Bitwarden vault" >&2
  echo "  2. Install the Bitwarden CLI: https://bitwarden.com/help/cli/" >&2
  exit 1
fi

KAMAL_REGISTRY_PASSWORD=$(cat config/credentials/kamal_registry_password.key)
MYSQL_ROOT_PASSWORD=$(RAILS_MASTER_KEY=$RAILS_MASTER_KEY rails credentials:fetch -e production database.password)
SKYLIGHT_AUTHENTICATION=$(RAILS_MASTER_KEY=$RAILS_MASTER_KEY rails credentials:fetch -e production skylight_authentication_token)
HONEYBADGER_API_KEY=$(RAILS_MASTER_KEY=$RAILS_MASTER_KEY rails credentials:fetch -e production honeybadger.api_key)
