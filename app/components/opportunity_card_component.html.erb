<div class="py-3">
  <div class="flex items-start justify-between gap-2">
    <h4 class="text-base font-semibold mb-0">
      <% if heading_url %>
        <%= link_to heading, heading_url, class: "hover:underline" %>
      <% else %>
        <%= heading %>
      <% end %>
    </h4>
    <% if internal? %>
      <%= render(BadgeComponent.new(type: :info, pill: true)) do %>EUTC<% end %>
    <% end %>
  </div>

  <p class="mt-1 mb-2 text-xs text-gray-500">
    Expires <%= l opportunity.expiry_date, format: :longy %>
    <% if compensation_label %>· <%= compensation_label %><% end %>
    <% if experience_label %>· <%= experience_label %><% end %>
  </p>

  <% if roles.any? %>
    <ul class="flex flex-col gap-1 mb-2">
      <% roles.each do |role| %>
        <li class="flex items-center gap-2 text-sm">
          <span class="font-medium"><%= role.position %></span>
          <%= render(BadgeComponent.new(type: :secondary)) do %><%= role.category_label %><% end %>
          <% if role.note.present? %>
            <span class="text-xs text-gray-500"><%= role.note %></span>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% end %>

  <% if detailed %>
    <div class="prose prose-sm max-w-none mb-2">
      <%= helpers.render_markdown opportunity.description %>
    </div>

    <% if submitter_name.present? %>
      <p class="text-xs text-gray-500 mb-1">Posted by <%= submitter_name %>.</p>
    <% end %>

    <% apply = opportunity.apply_url.present? %>
    <% contact = show_contact? && contact_email.present? %>
    <% if apply || contact %>
      <p class="text-sm">
        <% if apply %><%= link_to "Apply here", opportunity.apply_url, class: "text-primary hover:underline", target: "_blank", rel: "noopener" %><% end %>
        <% if apply && contact %> or <% end %>
        <% if contact %><%= apply ? "get in touch by clicking" : "Get in touch by clicking" %> <%= mail_to contact_email, "here" %><% end %>.
      </p>
    <% end %>
  <% end %>
</div>
