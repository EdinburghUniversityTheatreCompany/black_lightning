<% headers = [:title, :creator_full_name, :expiry_date, :approved] %>

<% field_sets = @opportunities.map do |opportunity|
  submitter = if opportunity.external?
    safe_join([ opportunity.submitter_name.to_s, " ", render(BadgeComponent.new(type: :warning).with_content("External")) ])
  elsif opportunity.on_behalf_of?
    safe_join([ user_link(opportunity.creator, false), " on behalf of #{opportunity.submitter_name} ",
                render(BadgeComponent.new(type: :warning).with_content("External")) ])
  else
    user_link(opportunity.creator, false)
  end

  {
    fields: [
      opportunity,
      submitter,
      l(opportunity.expiry_date, format: :longy),
      bool_icon(opportunity.approved)
    ],
    class: can?(:manage, Opportunity) ? opportunity.css_class : ''
  }
end %>

<%= render 'shared/pages/index_results', resources: @opportunities, resource_class: Opportunity, headers: headers, field_sets: field_sets %>
