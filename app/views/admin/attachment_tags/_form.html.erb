<%# locals: () %>

<%= simple_horizontal_form_for [:admin, @attachment_tag] do |f| %>
  <%= render('shared/pages/form', f: f) do %>
    <%= f.input :name %>
    <%= f.input :ordering, hint: 'Lowest will appear at the top.' %>
  
    <%= render Admin::MdEditorComponent.new(f: f, field: :description, rows: 12 )%>
  <% end %>
<% end %>
