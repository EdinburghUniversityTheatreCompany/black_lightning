<%# locals: (f:, fields:, div_class_additions: '') %>

<%- div_class_additions = div_class_additions + ' flex flex-row flex-wrap items-end gap-2' %>

<%= render layout: '/shared/form/fields_for_template', locals: {
  f: f,
  div_class_additions: div_class_additions
} do %>
    <% fields.each do |field| %>
        <div class="<%= field[:col_modifier] == 'auto' ? 'shrink-0' : 'flex-1' %>">
            <%= field[:field] %>
        </div>
    <% end %>
    <%- # If you need further customisation, you can add it with yield. %>
    <%- #= yield %>
<% end %>
