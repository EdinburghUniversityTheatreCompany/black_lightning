<h1>Opportunities</h1>

<% if @editable_block %>
<div class="mb-3">
  <%= display_block(@editable_block.name, false) %>
</div>
<% end %>

<% if @opportunities.count == 0 %>
  <%= display_block("No Opportunities", false) %>
<% else %>
  <div class="card mb-3">
    <ul class="list-group list-group-flush">
    <% @opportunities.each do |opportunity| %>
        <li class="list-group-item">
          <h4><%= opportunity.title %></h4>
          
          <p><small class="text-gray-500"><%= opportunity.creator&.name(@current_user) %> | This opportunity expires at <%= l opportunity.expiry_date, format: :longy %>.</small></p>

          <p> <%= render_markdown opportunity.description %></p>

          <% if opportunity.creator %>
            <% show_contact = opportunity.everyone? || (opportunity.members_only? && can?(:access, :backend)) %>
            <% if show_contact %>
              <% contact_email = opportunity.contact_email.presence || opportunity.creator.email %>
              <p>Please contact <%= opportunity.creator.name(@current_user) %> by clicking <%= mail_to contact_email, 'here' %>.</p>
            <% end %>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="mb-3"></div>
