<%# locals: () %>

<%= render Admin::CardComponent.new(title: "Questionnaires", flush: true) do %>
  <% if @show_current_term_only %>
    <p class="px-4 py-3 mb-0">By default, this display only includes questionnaires for events taking place during the current semester. Please use the search form if you want to view older questionnaires.</p>
  <% elsif @questionnaires.empty? %>
    <p class="px-4 py-3 mb-0">There are no questionnaires matching this search. Have you expanded the date range?</p>
  <% end %>

  <ul class="list-group list-group-flush">
    <% @questionnaires.each do |event_name, questionnaires| %>
      <%# If you change the anchor_id, please also change the anchor for the back button on the questionnaire show page. %>
      <li class="list-group-item list-group-item-secondary py-1">
        <small class="font-bold"><a id="<%= "#{event_name.to_url}-table" %>"><%= event_name %></a></small>
      </li>
      <% questionnaires.each do |questionnaire| %>
        <li class="list-group-item flex items-center gap-2">
          <span class="mr-auto"><%= get_link(questionnaire, :show, link_text: questionnaire.name, html_class: '') %></span>
          <%= get_link(questionnaire, :answer, http_method: :get, link_text: 'Answer') %>
          <%= get_link(questionnaire, :edit) %>
        </li>
      <% end %>
    <% end %>
  </ul>
<% end %>
