<p class="mb-3 text-gray-600">
  Submit your expenses here. The finance team reviews every claim, batches it to EUSA,
  and EUSA pays it into your bank account. You can also just email a receipt to
  <%= mail_to Reimbursements::CostCentre.default&.receive_mailbox %> and finish the claim here.
</p>

<% if current_person.nil? || !current_person.bank_details? %>
  <%= render AlertComponent.new(type: :warning) do %>
    We don't have your bank details yet. You can submit expenses, but they can't be
    approved until you
    <%= link_to "add your payment details", edit_admin_reimbursements_payment_details_path, class: "font-medium underline" %>.
  <% end %>
<% end %>

<%= render CardComponent.new(title: "Quick actions") do %>
  <div class="flex flex-wrap items-center gap-2">
    <%= link_to "New expense", new_admin_reimbursements_expense_path, class: btn_classes(:primary) %>
    <%= link_to "Payment details", edit_admin_reimbursements_payment_details_path, class: btn_classes(:secondary) %>
    <%= link_to "Refresh", admin_reimbursements_expenses_path(refresh: 1), class: btn_classes(:secondary) %>
  </div>
<% end %>

<% if @expenses.empty? %>
  <%= render CardComponent.new(title: @title) do %>
    <div class="py-4 text-center text-gray-600">
      No expenses yet.
      <%= link_to "Submit your first one", new_admin_reimbursements_expense_path, class: "font-medium underline" %>:
      upload the receipt and we'll fill in most of the form for you.
    </div>
  <% end %>
<% else %>
  <% headers = [ "Status", "Description", "Budget", "Amount", "Submitted", "Receipts", "" ] %>
  <% field_sets = @expenses.map do |expense|
       status = safe_join([
         render(BadgeComponent.new(type: Reimbursements::Status.badge_variant(expense.status)).with_content(expense.status)),
         (render(BadgeComponent.new(type: :warning, pill: true).with_content("Needs completion")) if expense.needs_completion?)
       ].compact, " ")
       description = safe_join([
         expense.description.presence || content_tag(:span, "(no description yet)", class: "text-gray-500"),
         (content_tag(:div, "Rejected: #{expense.rejection_reason}", class: "text-sm text-danger") if expense.status == Reimbursements::Status::REJECTED && expense.rejection_reason.present?)
       ].compact)
       {
         fields: [
           expense,
           status,
           description,
           expense.budget ? expense.budget.name : content_tag(:span, "No budget yet", class: "text-gray-500"),
           expense.amount ? number_to_currency(expense.amount, unit: "£") : "—",
           expense.submitted_at ? l(expense.submitted_at.to_date, format: :short) : "",
           expense.receipts.size,
           (link_to("Edit", edit_admin_reimbursements_expense_path(expense.record_id), class: btn_classes(:secondary, :sm)) if expense.editable?)
         ]
       }
     end %>
  <%= render "shared/pages/index_results",
        resources: @expenses, resource_class: Reimbursements::Expense,
        headers: headers, field_sets: field_sets,
        include_edit_button: false, include_link_to_item: false, include_pagination: false %>
<% end %>
