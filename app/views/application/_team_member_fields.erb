<%# locals: (f:, dynamic: nil) %>

<%= render '/shared/form/inline_fields_for_template',
    f: f,
    div_class_additions: 'team_member',
    fields: [
        { field:    f.hidden_field(:id) + 
                    f.hidden_field(:display_order, data: { display_order: true }) + 
                    content_tag(:span, "⠿", data: { sortable_handle: true }, style: "cursor: grab; font-size: 1.2rem; color: #aaa;"), 
                    col_modifier: 'auto' },
        { field: f.input_field(:position, collection: position_typeahead, allow_custom_input: true, wrapper: :inline_form) }, 
        { field:    render('shared/form/user_field', f: f, wrapper: :inline_form) },
        { field:    link_to_remove(f), col_modifier: 'auto' },
] %>
