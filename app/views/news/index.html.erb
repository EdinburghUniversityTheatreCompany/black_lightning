<% search_fields = {
    title_cont:             { slug: 'defaults.name' },
    body_cont:              { slug: 'defaults.description'},
    author_full_name_cont:  { slug: 'defaults.author'},
    date_range:             { type: :date_range, options: {  start_date_attribute: 'publish_date', end_date_attribute: 'publish_date'} }

} %>

<%= render "shared/pages/public/index",
      title: @title,
      editable_block_name: @editable_block_name,
      search_fields: search_fields,
      results_partial: index_results_partial %>

<% rss_icon = '<i class="fa-solid fa-square-rss" aria-hidden="true"></i> RSS Feed' %>
<%= link_to(rss_icon.html_safe, news_index_path(format: :rss), class: btn_classes(:secondary)) %><%# herb:disable erb-no-unsafe-raw %>
