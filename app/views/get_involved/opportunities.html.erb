<h1>Opportunities</h1>

<% if @editable_block %>
<div class="mb-3">
  <%= display_block(@editable_block.name, false) %>
</div>
<% end %>

<%# Filters via the shared (non-admin) search form. Submits as q[...] params, so the URLs stay
    shareable (e.g. ?q[company_slug_eq]=… for the societies cheat sheet). %>
<% search_fields = {
     roles_category_eq:    { type: :select, label: "Category",     collection: OpportunityRole.categories.map { |k, v| [ OpportunityRole.category_label(k), v ] } },
     company_slug_eq:      { type: :select, label: "Company",      collection: Company.internal_first.pluck(:name, :slug) },
     compensation_type_eq: { type: :select, label: "Compensation", collection: Opportunity.compensation_types.except("tbc").map { |k, v| [ k.humanize, v ] } },
     experience_level_eq:  { type: :select, label: "Experience",   collection: Opportunity.experience_levels.except("any").map { |k, v| [ k.humanize, v ] } }
   } %>
<%= render "shared/search_form", input_fields: search_fields, columns: 4, url: get_involved_opportunities_path %>

<div id="index-results">
  <%= render "opportunities_results" %>
</div>

<div class="mb-3"></div>
