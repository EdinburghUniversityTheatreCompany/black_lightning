<% search_fields = {
    title_cont:         { slug: 'defaults.title' },
    body_cont:          { slug: 'defaults.body' },
    reviewer_cont:      { slug: 'defaults.reviewer' },
    organisation_cont:  { slug: 'defaults.organisation' },
    rating_eq:          { slug: 'defaults.rating' },
    event_id_eq:        { slug: 'defaults.event', type: :select, collection: Event.accessible_by(current_ability).joins(:reviews).distinct }
} %>


<%= render 'shared/pages/index', resource_class: Review, resources: @reviews, content: render('index_results'), search_fields: search_fields %>
