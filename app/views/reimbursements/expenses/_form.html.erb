<%# Receipt-first expense form. The Stimulus controller posts the receipt to
    /reimbursements/expenses/extract and prefills the fields; everything still
    works with JavaScript disabled (plain manual form). %>
<%= simple_form_for form, url: url, method: method,
      html: { multipart: true,
              data: { controller: "reimbursements-receipt",
                      reimbursements_receipt_extract_url_value: extract_reimbursements_expenses_path } } do |f| %>

  <div class="mb-4 rounded border border-gray-200 p-3">
    <label class="font-medium" for="reimbursements_expense_form_receipts">
      Receipt or invoice <%= "(already attached — only add files to append)" unless form.require_receipts? %>
    </label>
    <p class="mb-2 text-sm text-gray-600">
      Upload this first — we'll read it and prefill the form for you.
      PDF or photo, max 5&nbsp;MB. Make sure it shows VAT where possible.
    </p>
    <%= f.input :receipts, as: :file, label: false,
          input_html: { multiple: true,
                        accept: Reimbursements::ExpenseForm::ALLOWED_RECEIPT_TYPES.join(","),
                        data: { reimbursements_receipt_target: "files",
                                action: "change->reimbursements-receipt#extract" } } %>
    <p class="mt-1 text-sm text-gray-600" aria-live="polite"
       data-reimbursements-receipt-target="status"></p>
  </div>

  <%= f.input :expense_type, label: "Type",
        collection: Reimbursements::Expense::TYPES, include_blank: false %>

  <div class="grid gap-3 sm:grid-cols-2">
    <%= f.input :amount, label: "Amount (£, incl. VAT)",
          hint: "What actually left your account, or the invoice total.",
          input_html: { inputmode: "decimal", data: { reimbursements_receipt_target: "amount" } } %>
    <%= f.input :amount_excl_vat, label: "Amount excl. VAT (£)",
          hint: "From the receipt. Only this comes out of your budget; equal to the total when no VAT is shown.",
          input_html: { inputmode: "decimal", data: { reimbursements_receipt_target: "amountExclVat" } } %>
  </div>

  <div data-reimbursements-receipt-target="vatWarning"
       class="<%= 'hidden' unless form.errors[:vat_acknowledged].any? || form.vat_missing? %> mb-3 rounded border border-warning/40 bg-warning/10 p-3">
    <label class="flex items-start gap-2">
      <%= f.check_box :vat_acknowledged, class: "mt-1" %>
      <span class="text-sm">
        This receipt doesn't itemise VAT, so the <strong>full amount</strong> counts against
        your budget — with a VAT receipt only the ex-VAT amount would. I understand, submit
        anyway (and I'll ask for a VAT receipt/invoice next time it's possible).
      </span>
    </label>
    <% if form.errors[:vat_acknowledged].any? %>
      <p class="mt-1 text-sm text-danger"><%= form.errors[:vat_acknowledged].to_sentence %></p>
    <% end %>
  </div>
  <%= f.hidden_field :vat_itemised, data: { reimbursements_receipt_target: "vatItemised" } %>

  <%= f.input :budget_record_id, label: "Budget",
        collection: budgets.map { |b| [ b.name, b.record_id ] },
        include_blank: "Choose a budget…",
        hint: "Not sure? Pick the closest and mention it in the description.",
        input_html: { data: { reimbursements_receipt_target: "budget" } } %>

  <%= f.input :description, label: "Description", hint: "What's it for?",
        input_html: { data: { reimbursements_receipt_target: "description" } } %>

  <%= f.input :payment_reference, label: "Payment reference",
        hint: "What EUSA puts on the bank transfer. Invoices usually specify one; otherwise the invoice number or a short label.",
        input_html: { maxlength: Reimbursements::ExpenseForm::REFERENCE_LIMIT,
                      data: { reimbursements_receipt_target: "reference",
                              action: "input->reimbursements-receipt#updateCounter" } } %>
  <p class="-mt-2 mb-3 text-sm text-gray-500">
    <span data-reimbursements-receipt-target="referenceCounter"></span>
  </p>

  <% overrides_open = form.payee_name_override.present? || form.errors[:sort_code_override].any? || form.errors[:account_number_override].any? %>
  <%= tag.details class: "mb-3", open: overrides_open do %>
    <summary class="cursor-pointer font-medium">Paying an invoice to someone else's account?</summary>
    <div class="mt-2 grid gap-3 rounded border border-gray-200 p-3 sm:grid-cols-3">
      <%= f.input :payee_name_override, label: "Payee account name" %>
      <%= f.input :sort_code_override, label: "Payee sort code" %>
      <%= f.input :account_number_override, label: "Payee account number" %>
      <p class="text-sm text-gray-600 sm:col-span-3">
        Fill this out only when EUSA should pay a third party directly (e.g. an invoice).
        Leave blank to be reimbursed yourself.
      </p>
    </div>
  <% end %>

  <div class="mt-3 flex items-center gap-2">
    <%= f.submit submit_label, class: btn_classes(:primary) %>
    <%= link_to "Cancel", reimbursements_expenses_path, class: btn_classes(:secondary) %>
  </div>
<% end %>
