<%
search_fields = {
  show_title_cont:      { slug: 'defaults.proposal_title' },
  users_full_name_cont: { slug: 'defaults.user' },

  proposal_text_cont:   { slug: 'defaults.proposal_text' },
  publicity_text_cont:  { slug: 'defaults.publicity_text' },

  date_range:           { type: :date_range, options: { start_date_attribute: 'call_submission_deadline', end_date_attribute: 'call_editing_deadline' } },

  random_button:        { type: :submit_button, action: :Random },
}

status_order = { "successful" => 0, "unsuccessful" => 1, "approved" => 2, "rejected" => 3, "awaiting_approval" => 4 }
%>

<% content_for :proposal_archive_content do %>
  <% if @proposals.any? %>
    <% @proposals.each_with_index do |(call, proposals), index| %>

      <h5 class="font-semibold text-gray-800 mb-2">
        <%= call.name %>
        <span class="font-normal text-sm text-gray-600">(Submission: <%= l call.submission_deadline, format: :longy %> | Editing: <%= l call.editing_deadline, format: :longy %>)</span>
      </h5>

      <% proposals.sort_by { |p| status_order.fetch(p.status, 99) }.each do |proposal| %>
        <div class="flex items-center py-1.5 border-b border-gray-100 last:border-b-0 hover:bg-gray-50 -mx-4 px-4">
          <%= get_link proposal, :show %>
          <div class="flex gap-1 ml-2">
            <%= proposal.labels false, show_debtors: false %>
          </div>
        </div>
      <% end %>
    <% end %>
  <% else %>
    <p class="text-gray-500">There are no proposals found for this search.</p>
  <% end %>
<% end %>

<%= render 'shared/pages/index', resource_class: Admin::Proposals::Call, resources: @calls, content: yield(:proposal_archive_content),
  show_new_button: false, search_fields: search_fields %>
