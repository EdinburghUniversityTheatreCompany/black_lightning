<%# locals: (title:, card_class: '', body_class: '', header_class: '', title_right: '', id: "#{title.to_url}_container", start_open: false) -%>

<div class="card <%= card_class %>">
  <div class="card-header <%= header_class %>">
    <a class="btn btn-link" type="button" data-toggle="collapse" data-target="#<%= id %>" data-bs-toggle="collapse" data-bs-target="#<%= id %>" role="button" aria-expanded="<%= start_open %>" aria-controls="<%= id %>">
      <%= generate_icon_prefix('chevron-down', title) %>
    </a>
    <%= title_right %>
  </div>

  <div class="collapse<%= ' show' if start_open %>" id="<%= id %>">
    <div class="card-body <%= body_class %>">
      <%= yield %>
    </div>
  </div>
</div>
