<% items = @news.collect { |news| {
  url: url_for(news),
  image: news.fetch_image,
  header: news.title,
  paragraphs: [
    { content: l(news.publish_date, format: :longy), small: true },
    { content: render_plain(news.preview) }
  ],
  button_text: 'Read Full Article'
} } %>

<%= render "shared/pages/public/index_list", items: items, resources: @news, editable_block_name: @editable_block_name %>
