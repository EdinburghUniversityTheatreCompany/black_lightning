<header class="bg-white border-b border-gray-200 sticky top-0 z-30">
  <div class="h-14 flex items-center px-4 gap-4">
    <button type="button"
            class="text-gray-500 hover:text-gray-700 shrink-0"
            data-action="admin--sidebar#toggle">
      <i class="fas fa-bars" aria-hidden="true"></i>
      <span class="sr-only">Toggle sidebar</span>
    </button>

    <div class="flex-1 flex items-center gap-3 min-w-0">
      <% if @title %>
        <h1 class="text-lg font-semibold text-gray-900 truncate"><%= @title %></h1>
      <% end %>
      <% if has_badges? %>
        <div class="hidden lg:flex items-center flex-wrap gap-2">
          <% @header_badges.each do |badge| %>
            <%= helpers.generate_label(badge[:label_class], badge[:text]) %>
          <% end %>
        </div>
      <% end %>
    </div>

    <nav aria-label="Breadcrumb" class="admin-breadcrumb shrink-0">
      <ol class="flex text-sm text-gray-400 gap-1">
        <li><%= helpers.render_breadcrumbs separator: " / " %></li>
      </ol>
    </nav>
  </div>

  <% if has_badges? %>
    <div class="flex lg:hidden flex-wrap gap-2 px-4 pb-2">
      <% @header_badges.each do |badge| %>
        <%= helpers.generate_label(badge[:label_class], badge[:text]) %>
      <% end %>
    </div>
  <% end %>
</header>
