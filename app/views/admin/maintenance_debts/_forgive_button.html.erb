<%# locals: (debt:) %>

<% if debt.status != :forgiven %>
  <%= get_link debt, :forgive, http_method: :put, link_text: 'Forgive',
               confirm: "Forgiving " + debt.user.name(current_user) + "'s debt",
               detail: "If you forgive a debt a theatre manager fairy will be squished by a pineapple#{ ' and the associated maintenance session will be disassociated' if debt.maintenance_attendance.present? }."
  %>
<% end %>
