<%= simple_horizontal_form_for([:admin, @complaint]) do |f| %>
  <%= render('shared/pages/form', f: f) do %>
    <% fields = { 
      created_at: l(@complaint.created_at, format: :longy),
      description: render_markdown(@complaint.description)
    } %>

    <%= render 'shared/basic_fields', fields: fields %>

    <%= f.input :resolved %>
    <%= render Admin::MdEditorComponent.new(f: f, field: :comments )%>
  <% end %>
<% end %>
