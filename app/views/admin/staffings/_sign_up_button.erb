<%# locals: (job:) %>

<% sign_up_text = '<i class="fa-solid fa-pen-to-square" aria-hidden="true"></i> Sign Up'.html_safe %>
<% date = l job.staffable.start_time, format: :long %>

<turbo-frame id="<%= dom_id(job, :sign_up) %>">
  <%= button_to sign_up_text, admin_staffing_sign_up_path(job), method: :put,
      class: "btn btn-secondary staffing-sign-up",
      form: {
        data: {
          turbo: true,
          turbo_confirm: "Confirm staffing as #{job.name} for #{job.staffable.show_title} on #{date}"
        }
      } %>
</turbo-frame>
