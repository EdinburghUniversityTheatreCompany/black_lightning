<% headers = [:name, ''] %>

<% field_sets = @picture_tags.map { |picture_tag| {
  fields: [
    picture_tag,
    get_link_to_pictures_for_tag(picture_tag)
  ] } } %>

<%= render 'shared/pages/index_results', resources: @picture_tags, resource_class: PictureTag, headers: headers, field_sets: field_sets %>
