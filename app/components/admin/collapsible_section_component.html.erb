<div class="bg-white rounded border border-gray-200 mb-4 <%= @html_class %>"
     data-controller="collapsible"
     data-collapsible-open-value="<%= @start_open %>">
  <button type="button"
          class="w-full px-4 py-3 border-b font-medium flex items-center text-left <%= header_classes %>"
          data-action="click->collapsible#toggle">
    <span class="text-base font-semibold flex-1"><%= @title %></span>
    <% if @title_right %>
      <%= @title_right %>
    <% end %>
    <span class="flex items-center gap-1 ml-auto opacity-70">
      <span class="when-closed"><i class="fas fa-plus" aria-hidden="true"></i></span>
      <span class="when-open"><i class="fas fa-minus" aria-hidden="true"></i></span>
    </span>
  </button>

  <div data-collapsible-target="content" class="<%= 'hidden' unless @start_open %>">
    <% if @flush %>
      <%= content %>
    <% else %>
      <div class="p-4">
        <%= content %>
      </div>
    <% end %>
  </div>
</div>
