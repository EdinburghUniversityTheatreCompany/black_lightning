<div class="card mt-3 <%= card_class %>">
  <div class="card-header">
    <h5 class="mb-0">Debt Summary</h5>
  </div>
  <div class="card-body">
    <p class="<%= 'mb-0' if check_only? %>">
      <strong><%= @user.name(@current_user) %></strong> is currently
      <% if check_only? %>
        <span class="badge <%= badge_class %>"><%= status_label %></span>
      <% else %>
        <strong><%= @user.debt_message_suffix %></strong>.
      <% end %>
    </p>

    <% unless check_only? %>
      <div class="row mb-3">
        <div class="col-md-6">
          <h6>Staffing Debts</h6>
          <ul class="list-unstyled mb-0">
            <li>Unfulfilled: <%= @user.admin_staffing_debts.unfulfilled.count %></li>
            <li>Unlinked jobs: <%= @user.staffing_jobs_unlinked_count %></li>
          </ul>
          <%= link_to 'View all', helpers.admin_staffing_debts_path(user_id: @user.id), class: 'btn btn-sm btn-secondary mt-2' %>
        </div>
        <div class="col-md-6">
          <h6>Maintenance Debts</h6>
          <ul class="list-unstyled mb-0">
            <li>Unfulfilled: <%= @user.admin_maintenance_debts.unfulfilled.count %></li>
            <li>Unlinked attendances: <%= @user.maintenance_attendances_unlinked_count %></li>
          </ul>
          <%= link_to 'View all', helpers.admin_maintenance_debts_path(user_id: @user.id), class: 'btn btn-sm btn-secondary mt-2' %>
        </div>
      </div>

      <% if past_staffing.any? || past_maintenance.any? %>
        <h6 class="mt-3">Unfulfilled Past Debts</h6>
        <table class="table table-sm table-striped">
          <thead>
            <tr>
              <th>Type</th>
              <th>Show</th>
              <th>Due By</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% past_staffing.includes(:show).each do |debt| %>
              <tr class="<%= debt.css_class %>">
                <td>Staffing</td>
                <td><%= helpers.get_link(debt.show, :show) %></td>
                <td><%= debt.due_by %></td>
                <td><%= helpers.formatted_status_for_debt(debt) %></td>
              </tr>
            <% end %>
            <% past_maintenance.includes(:show).each do |debt| %>
              <tr class="<%= debt.css_class %>">
                <td>Maintenance</td>
                <td><%= helpers.get_link(debt.show, :show) %></td>
                <td><%= debt.due_by %></td>
                <td><%= helpers.formatted_status_for_debt(debt) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>

      <% if has_upcoming? %>
        <h6 class="mt-3">Upcoming Debts</h6>
        <table class="table table-sm table-striped">
          <thead>
            <tr>
              <th>Type</th>
              <th>Show</th>
              <th>Due By</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% upcoming_staffing.includes(:show).each do |debt| %>
              <tr class="<%= debt.css_class %>">
                <td>Staffing</td>
                <td><%= helpers.get_link(debt.show, :show) %></td>
                <td><%= debt.due_by %></td>
                <td><%= helpers.formatted_status_for_debt(debt) %></td>
              </tr>
            <% end %>
            <% upcoming_maintenance.includes(:show).each do |debt| %>
              <tr class="<%= debt.css_class %>">
                <td>Maintenance</td>
                <td><%= helpers.get_link(debt.show, :show) %></td>
                <td><%= debt.due_by %></td>
                <td><%= helpers.formatted_status_for_debt(debt) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>

      <% if past_staffing.empty? && past_maintenance.empty? && !has_upcoming? %>
        <p class="text-muted mb-0">No unfulfilled or upcoming debts.</p>
      <% end %>
    <% end %>
  </div>
</div>
