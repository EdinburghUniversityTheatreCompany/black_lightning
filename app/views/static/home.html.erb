<div class="row">
  <div class="col-md-6 col-xl-8">
    <% carousel_config = CarouselItem::CAROUSEL_CONFIG.fetch("Home", {}) %>
    <% cache [ @carousel_events, @standard_carousel_items ] do %>
      <%= render 'shared/carousel',
            id: 'homeCarousel',
            carousel_items: combine_events_with_carousel_items(@carousel_events, @standard_carousel_items),
            aspect_ratio: carousel_config[:aspect_ratio]&.join("/"),
            fit_mode: carousel_config.fetch(:fit_mode, "cover") %>
    <% end %>

    <div class="card mt-3">
      <div class="card-header">
        <h4>What's On</h4>
      </div>
      <div class="card-body">
        <% cache @events do %>
          <% if @events.empty? %>
            <%= display_block("Home - No Events On", false) %>
          <% else %>
            <% items = @events.collect { |event| {
              event: event,
              paragraphs: [
                { content: event.date_and_price, small: true },
                { content: event.short_blurb },
                { content: link_to('View Details', event, class: 'btn btn-primary'), class: 'mt-auto' }
              ] } } %>
            <%= render('shared/pages/public/events_grid', items: items, col_size: 8) %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-md-6 col-xl-4">
    <%= render "static/opportunities_widget", home_opportunities: @home_opportunities %>

    <div class="card mt-3">
      <div class="card-header">
        <h4>News</h4>
      </div>

      <ul class="list-group list-group-flush">
        <li class="list-group-item">
          <%= display_block("Home - News", false) %>
        </li>
        <% cache @news do %>
          <% @news.each do |news_item| %>
            <li class="list-group-item">
              <h5 class="card-title"><%= link_to news_item.title, news_path(news_item) %></h5>

              <p class="card-text"><small class="text-muted"><%= l(news_item.publish_date, format: :longy) %> by <%= news_item.author.name %></small></p>

              <p class="card-text"><%= render_plain(news_item.preview) %></p>

              <p class="card-text"><%= link_to 'Read More', news_path(news_item), class: 'btn btn-primary' %></p>
            </li>
          <% end %>
        <% end %>
      </ul>

      <div class="card-footer">
        <%= link_to 'Read all news', news_index_path %>
      </div>
    </div>
  </div>
</div>
