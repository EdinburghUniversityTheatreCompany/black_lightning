<div class="bg-white rounded border border-gray-200 mb-4">
  <div class="p-4 overflow-hidden">
    <% if @user.avatar.present? %>
      <div class="float-left mr-4 mb-2">
        <%= render 'shared/image', image: @user.avatar, variant: helpers.square_thumb_variant, proxy: true, eager_load: false, image_options: { class: "rounded w-32 h-32 object-cover" } %>
      </div>
    <% end %>
    <% if @user.bio.present? %>
      <div class="prose max-w-none">
        <%= helpers.render_markdown @user.bio %>
      </div>
    <% else %>
      <p class="text-gray-400 italic mb-0">No bio set.</p>
    <% end %>
  </div>
</div>
