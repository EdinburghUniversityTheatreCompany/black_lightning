<% headers = [:name, :ordering, ''] %>

<% field_sets = @attachment_tags.map { |attachment_tag| {
  fields: [
    attachment_tag,
    attachment_tag.ordering,
    get_link_to_attachments_for_tag(attachment_tag)
  ] } } %>

<%= render 'shared/pages/index_results', resources: @attachment_tags, resource_class: AttachmentTag, headers: headers, field_sets: field_sets %>
