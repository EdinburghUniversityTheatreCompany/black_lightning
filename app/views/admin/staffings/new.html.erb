<% content_for :head do %>
  <meta name="templates-base-url" content="/admin/staffing_templates">
  <meta name="templates-items-type" content="jobs">
<% end %>

<div data-controller="template-loader">
  <%= simple_horizontal_form_for @staffing do |f| %>
    <% content_for :extra_form_actions do %>
      <button type="button" class="<%= btn_classes(:secondary) %>" data-action="click->template-loader#open">Load Template</button>
    <% end %>

    <%= render('shared/pages/form', f: f) do %>
      <%= render 'form_base', f: f %>

      <div id="dates_container" data-controller="staffing-date-fields">
        <h3>Dates</h3>
        <button type="button" class="<%= btn_classes(:secondary) %>" data-action="click->staffing-date-fields#addDate" data-staffing-date-fields-target="addButton"><i class="fa-solid fa-calendar-plus" aria-hidden="true"></i> Add Date</button>

        <div style="display: none" class="control-group datetime" data-staffing-date-fields-target="blueprint">
          <div class="flex flex-wrap items-center gap-2">
            <div class="flex-1">
              <input class="form-control is-valid datetime required mb-2" required aria-required="true" autocomplete="off" value="<%= @default_start_time.strftime("%Y-%m-%dT%T") %>" type="datetime-local" data-staffing-field="start">
            </div>
            <div class="flex-1">
              <input class="form-control is-valid datetime required mb-2" required aria-required="true" autocomplete="off" value="<%= @default_end_time.strftime("%Y-%m-%dT%T") %>" type="datetime-local" data-staffing-field="end">
            </div>
            <div class="shrink-0">
              <button type="button" class="<%= btn_classes(:danger) %> mb-2" data-action="click->staffing-date-fields#removeDate"><%= remove_button_text %></button>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  <% end %>

  <%= render '/shared/form/template_modal', header: 'Select Jobs from Template', template_model: Admin::StaffingTemplate %>
</div>
