{
    "dependencies": {
        "@fancyapps/ui": "^6.1.14",
        "@fortawesome/fontawesome-free": "^6.1.1",
        "@popperjs/core": "^2.11.8",
        "@hotwired/turbo-rails": "^8.0.0",
        "@rails/activestorage": "^8",
        "@stimulus-components/rails-nested-form": "^5.0.0",
        "@toast-ui/editor": "^3.2.2",
        "admin-lte": "^3.2.0",
        "autoprefixer": "^10.4.19",
        "babel-loader": "8.2.2",
        "bootstrap": "^5.3.3",
        "bootstrap-icons": "^1.11.3",
        "channels": "^0.0.4",
        "dropzone": "^5.9.2",
        "jquery": "^3.7.1",
        "jquery-slimscroll": "^1.3.8",
"leaflet": "^1.9.4",
        "moment": "^2.29.4",
        "nodemon": "^3.1.3",
        "postcss": "^8.4.38",
        "postcss-cli": "^11.0.0",
        "sass": "^1.77.6",
        "stimulus": "^3.0.0",
        "stimulus-rails-nested-form": "^4.1.0",
        "sweetalert2": "^11.11.1",
        "tom-select": "^2.6.0",
        "vivagraphjs": "^0.12.0",
        "webpack": "^5.92.0",
        "webpack-cli": "^5.1.4"
    },
    "scripts": {
        "build": "yarn webpack --config webpack.config.js",
        "build:css": "yarn build:css:compile && yarn build:css:prefix",
        "build:css:compile": "yarn sass ./app/assets/stylesheets/entrypoints:./app/assets/builds --no-source-map --load-path=node_modules",
        "build:css:prefix": "yarn postcss ./app/assets/builds/application.css --use=autoprefixer --output=./app/assets/builds/application.css",
        "watch:css": "yarn nodemon --watch ./app/assets/stylesheets/ --ext scss --exec \"yarn build:css\""
    },
    "browserslist": [
        "defaults"
    ],
    "devDependencies": {
        "imports-loader": "^5.0.0"
    }
}
