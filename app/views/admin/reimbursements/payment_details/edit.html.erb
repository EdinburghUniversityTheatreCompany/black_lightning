<p class="mb-3 text-gray-600">
  EUSA pays reimbursements by bank transfer, so we need the account you want paying
  into. These details are stored in the finance team's payee registry and are only
  visible to them.
</p>

<%= simple_horizontal_form_for @form, url: admin_reimbursements_payment_details_path, method: :patch do |f| %>
  <% content_for :override_card_footer do %>
    <div class="form-actions flex flex-wrap items-center gap-2">
      <%= f.button :submit, "Save details", class: btn_classes(:primary) %>
      <%= link_to "Cancel", admin_reimbursements_expenses_path, class: btn_classes(:secondary) %>
    </div>
  <% end %>

  <%= render('shared/pages/form', f: f) do %>
    <%= f.input :name, label: "Account holder name", hint: "As it appears on your bank account." %>
    <%= f.input :sort_code, label: "Sort code", placeholder: "80-22-60" %>
    <%= f.input :account_number, label: "Account number", placeholder: "12345678" %>
  <% end %>
<% end %>
