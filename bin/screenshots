#!/usr/bin/env python3
"""
Multi-page screenshot tool for Black Lightning dev server.

Usage:
  bin/screenshots                    # use config/screenshots.yml or default list
  bin/screenshots /shows /news /     # capture specific paths

Saves all screenshots to tmp/screenshots/batch_<timestamp>/
Generates an index.html with all screenshots in a responsive grid.
"""

import argparse
import html
import socket
import sys
import threading
from concurrent.futures import ThreadPoolExecutor, as_completed
from datetime import datetime
from pathlib import Path
from urllib.parse import quote

# Try to load YAML (optional — only needed for config file)
try:
    import yaml
    HAS_YAML = True
except ImportError:
    HAS_YAML = False

try:
    from playwright.sync_api import sync_playwright
except ImportError:
    print("ERROR: playwright not installed. Run: pip install playwright && playwright install chromium")
    sys.exit(1)

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------

DEFAULT_HOST = "localhost"
DEFAULT_PORT = 3000
DEFAULT_TOKEN = "claude-screenshot-token"
DEFAULT_WIDTH = 1280
DEFAULT_HEIGHT = 720
DEFAULT_WAIT_MS = 1500

DEFAULT_PATHS = [
    "/",
    "/shows",
    "/news",
    "/venues",
    "/get_involved",
    "/about",
    "/complaints/new",
    "/users/sign_in",
]

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def find_project_root():
    """Find the project root by locating this script's parent."""
    script_path = Path(__file__).resolve()
    # bin/screenshots -> project root is parent of bin/
    return script_path.parent.parent


def load_pages_from_config(config_path: Path) -> list[str] | None:
    """Load pages list from config/screenshots.yml. Returns None if unavailable."""
    if not config_path.exists():
        return None
    if not HAS_YAML:
        print(f"WARNING: {config_path} exists but PyYAML is not installed. Falling back to defaults.")
        print("         Install with: pip install pyyaml")
        return None
    with open(config_path) as f:
        data = yaml.safe_load(f)
    if not data or "pages" not in data:
        return None
    return [str(p) for p in data["pages"]]


def path_to_filename(path: str) -> str:
    """Convert a URL path to a safe filename."""
    safe = path.strip("/").replace("/", "__") or "home"
    return f"{safe}.png"


def auth_url(host: str, port: int, token: str, path: str) -> str:
    encoded_path = quote(path, safe="/?&=")
    return f"http://{host}:{port}/dev_auth/login?token={token}&redirect_to={encoded_path}"


def take_screenshot(path: str, output_dir: Path, host: str, port: int, token: str,
                    width: int, height: int, wait_ms: int) -> tuple[str, str | None, str | None]:
    """
    Capture a single screenshot. Returns (path, filename, error_message).
    Each call spins up its own browser context (thread-safe with sync_playwright).
    """
    filename = path_to_filename(path)
    output_path = output_dir / filename

    try:
        with sync_playwright() as p:
            browser = p.chromium.launch(headless=True)
            context = browser.new_context(viewport={"width": width, "height": height})
            page = context.new_page()

            # Authenticate via dev auth bypass
            login_url = auth_url(host, port, token, path)
            page.goto(login_url, wait_until="networkidle", timeout=30000)
            page.wait_for_timeout(wait_ms)

            page.screenshot(path=str(output_path), full_page=False)
            browser.close()

        return (path, filename, None)
    except Exception as e:
        return (path, None, str(e))


# ---------------------------------------------------------------------------
# HTML index generation
# ---------------------------------------------------------------------------

def generate_index_html(output_dir: Path, results: list[tuple[str, str | None, str | None]]) -> Path:
    """Generate index.html with a responsive grid of all screenshots."""

    rows = []
    for path, filename, error in results:
        if filename and (output_dir / filename).exists():
            rows.append(f"""
    <figure class="screenshot-card">
      <img src="{html.escape(filename)}" alt="{html.escape(path)}" loading="lazy">
      <figcaption><code>{html.escape(path)}</code></figcaption>
    </figure>""")
        else:
            msg = html.escape(error or "Unknown error")
            rows.append(f"""
    <figure class="screenshot-card error">
      <div class="error-placeholder">Failed to capture</div>
      <figcaption><code>{html.escape(path)}</code><br><small class="error-msg">{msg}</small></figcaption>
    </figure>""")

    cards_html = "\n".join(rows)
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    total = len(results)
    success = sum(1 for _, fn, _ in results if fn)

    html = f"""<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Screenshots — {timestamp}</title>
  <style>
    *, *::before, *::after {{ box-sizing: border-box; }}
    body {{
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #0f1117;
      color: #e2e8f0;
      margin: 0;
      padding: 2rem;
    }}
    h1 {{ font-size: 1.5rem; margin-bottom: 0.25rem; }}
    .meta {{ color: #94a3b8; font-size: 0.875rem; margin-bottom: 2rem; }}
    .grid {{
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
      gap: 1.5rem;
    }}
    .screenshot-card {{
      background: #1e2130;
      border-radius: 0.75rem;
      overflow: hidden;
      margin: 0;
      border: 1px solid #2d3348;
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }}
    .screenshot-card:hover {{
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(0,0,0,0.4);
    }}
    .screenshot-card img {{
      width: 100%;
      display: block;
      border-bottom: 1px solid #2d3348;
    }}
    .screenshot-card a {{
      display: block;
    }}
    figcaption {{
      padding: 0.75rem 1rem;
      font-size: 0.875rem;
    }}
    figcaption code {{
      font-family: "SF Mono", "Fira Code", monospace;
      color: #7dd3fc;
    }}
    .error-placeholder {{
      height: 200px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #2d1515;
      color: #f87171;
      font-size: 0.875rem;
    }}
    .error-msg {{
      color: #f87171;
      font-size: 0.75rem;
      word-break: break-all;
    }}
  </style>
</head>
<body>
  <h1>Screenshots</h1>
  <p class="meta">Captured {success}/{total} pages &middot; {timestamp}</p>
  <div class="grid">
{cards_html}
  </div>
</body>
</html>
"""

    index_path = output_dir / "index.html"
    index_path.write_text(html)
    return index_path


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        description="Capture multi-page screenshots of the local dev server in parallel."
    )
    parser.add_argument("paths", nargs="*", help="URL paths to screenshot (e.g. / /shows /news)")
    parser.add_argument("--host", default=DEFAULT_HOST)
    parser.add_argument("--port", type=int, default=DEFAULT_PORT)
    parser.add_argument("--token", default=DEFAULT_TOKEN)
    parser.add_argument("--width", type=int, default=DEFAULT_WIDTH)
    parser.add_argument("--height", type=int, default=DEFAULT_HEIGHT)
    parser.add_argument("--wait", type=int, default=DEFAULT_WAIT_MS, help="Wait ms after load")
    parser.add_argument("--workers", type=int, default=4, help="Parallel browser workers")
    args = parser.parse_args()

    project_root = find_project_root()

    # Determine which pages to screenshot
    if args.paths:
        pages = args.paths
        print(f"Using {len(pages)} paths from CLI arguments.")
    else:
        config_path = project_root / "config" / "screenshots.yml"
        pages = load_pages_from_config(config_path)
        if pages:
            print(f"Loaded {len(pages)} pages from {config_path}")
        else:
            pages = DEFAULT_PATHS
            print(f"Using {len(pages)} default pages.")

    # Create output directory
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    output_dir = project_root / "tmp" / "screenshots" / f"batch_{timestamp}"
    output_dir.mkdir(parents=True, exist_ok=True)
    print(f"Output directory: {output_dir}")

    # Check server is running before attempting any captures
    try:
        sock = socket.create_connection((args.host, args.port), timeout=2)
        sock.close()
    except (socket.timeout, ConnectionRefusedError, OSError):
        print(f"\nERROR: Dev server is not running on {args.host}:{args.port}")
        print("       Start it with: bin/dev")
        sys.exit(1)

    # Capture screenshots in parallel
    results: list[tuple[str, str | None, str | None]] = [None] * len(pages)
    lock = threading.Lock()

    def capture(idx_path):
        idx, path = idx_path
        print(f"  [{idx+1}/{len(pages)}] Capturing {path} ...")
        result = take_screenshot(
            path, output_dir,
            args.host, args.port, args.token,
            args.width, args.height, args.wait
        )
        path_str, filename, error = result
        with lock:
            if error:
                print(f"  ERROR {path}: {error}")
            else:
                print(f"  OK    {path} -> {filename}")
        return idx, result

    print(f"\nCapturing {len(pages)} pages with {args.workers} parallel workers...\n")
    with ThreadPoolExecutor(max_workers=args.workers) as executor:
        futures = {executor.submit(capture, (i, p)): i for i, p in enumerate(pages)}
        for future in as_completed(futures):
            idx, result = future.result()
            results[idx] = result

    # Generate index
    print("\nGenerating index.html...")
    index_path = generate_index_html(output_dir, results)

    success = sum(1 for _, fn, _ in results if fn)
    print(f"\nDone! {success}/{len(pages)} screenshots captured.")
    print(f"\nIndex: {index_path}")
    print(f"Open:  xdg-open '{index_path}' 2>/dev/null || open '{index_path}'")


if __name__ == "__main__":
    main()
